@page "/principal/fornecedores/cadastro/novo"
@using EUROERP.Application.Address
@using EUROERP.Application.Suppliers
@using EUROERP.Application.Products
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<PageTitle>Novo Fornecedor</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Novo Fornecedor</h5>
    <a class="btn btn-outline-secondary btn-sm" href="/principal/fornecedores/cadastro">Voltar à lista</a>
</div>

<SuccessModal Show="_showSuccessModal" Message="@_successModalMessage" OnClosed="HideSuccessModal" />
<HelpModal Show="_showPaymentPlanHelp" Title="Plano de pagamento" OnClosed="HidePaymentPlanHelp">
    <p class="mb-0">É o prazo de pagamento parcelado para o fornecedor.</p>
    <p class="mb-0 mt-2">Ex.: 30, 60, 90 significa 30 dias, 60 dias e 90 dias.</p>
</HelpModal>

<div class="card">
    <div class="card-body">
        @if (!string.IsNullOrEmpty(_errorMessage)) { <div class="alert alert-danger">@_errorMessage</div> }

        <EditForm Model="_model" OnValidSubmit="Create" OnInvalidSubmit="OnSubmitWithErrors" FormName="newSupplier">
            <DataAnnotationsValidator />

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Identificação</div>
                <div class="card-body py-2">
                    <div class="row g-2 mb-2">
                        <div class="col-md-2">
                            <label class="form-label">Grupo <span class="text-danger">*</span></label>
                            <select class="form-select form-select-sm" @bind="_model.SupplierGroupId">
                                @foreach (var g in _groups.Where(x => x.Id > 0))
                                {
                                    <option value="@g.Id">@g.Name</option>
                                }
                            </select>
                            <ValidationMessage For="@(() => _model.SupplierGroupId)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Razão Social <span class="text-danger">*</span></label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.SocialName" />
                            <ValidationMessage For="@(() => _model.SocialName)" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">CNPJ / CPF</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Cnpj" />
                            <ValidationMessage For="@(() => _model.Cnpj)" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Insc. Estadual</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.StateInscr" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Contato</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Contact" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Endereço</div>
                <div class="card-body py-2">
                    <AddressByCep @bind-AddressStreet="_model.AddressStreet"
                                 @bind-AddressNumber="_model.AddressNumber"
                                 @bind-AddressComplement="_model.AddressComplement"
                                 @bind-AddressBlock="_model.AddressBlock"
                                 @bind-AddressZipCode="_model.AddressZipCode"
                                 @bind-AddressStateId="_model.AddressStateId"
                                 @bind-AddressCityName="_model.AddressCityName"
                                 @bind-AddressCityIbge="_model.AddressCityIbge"
                                 States="_states" ValidationForCep="@(() => _model.AddressZipCode)" />
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Contato</div>
                <div class="card-body py-2">
                    <div class="row g-2 mb-2">
                        <div class="col-md-3">
                            <label class="form-label">Telefone 1</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Phone1" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Telefone 2</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Phone2" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Telefone 3</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Phone3" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Celular</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Celular" />
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <label class="form-label">E-mail</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Email" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Banco</div>
                <div class="card-body py-2">
                    <div class="row g-2 mb-2">
                        <div class="col-md-3">
                            <label class="form-label">Banco</label>
                            <select class="form-select form-select-sm" @bind="_model.BankInfoBankId">
                                @foreach (var b in _banks)
                                {
                                    <option value="@(b.Id == 0 ? (byte?)null : (byte)b.Id)">@b.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Agência</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.BankInfoAgency" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Conta</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.BankInfoAccNo" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Favorecido</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.BankInfoName" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Swift Code</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.SwffitCode" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Comercial</div>
                <div class="card-body py-2">
                    <div class="row g-2 mb-2">
                        <div class="col-md-2">
                            <label class="form-label">Modo pagto.</label>
                            <select class="form-select form-select-sm" @bind="_model.PaymentMethodId">
                                @foreach (var pm in _paymentMethods)
                                {
                                    <option value="@(pm.Id == 0 ? (byte?)null : (byte)pm.Id)">@pm.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Prazo</label>
                            <input type="number" min="0" max="255" class="form-control form-control-sm" value="@_payTermInt" @onchange="@(e => SetPayTermFromChange(e))" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label d-flex align-items-center gap-1">
                                Plano pagto.
                                <button type="button" class="help-icon-btn" @onclick="ShowPaymentPlanHelp" title="Ajuda">?</button>
                            </label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.PaymentPlan" placeholder="30, 60, 90" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Desconto %</label>
                            <InputNumber class="form-control form-control-sm" @bind-Value="_model.Discount" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Custo transp. %</label>
                            <InputNumber class="form-control form-control-sm" @bind-Value="_model.CostTransport" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Estoque (dias)</label>
                            <input type="number" min="0" max="255" class="form-control form-control-sm" value="@_stockDaysInt" @onchange="@(e => SetStockDaysFromChange(e))" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Transportadoras</div>
                <div class="card-body py-2">
                    <div class="border rounded p-2" style="max-height: 150px; overflow-y: auto;">
                        @foreach (var d in _deliverySuppliers.Where(x => x.Id > 0))
                        {
                            var deliveryId = d.Id;
                            var isChecked = _model.DeliverySupplierIds.Contains(deliveryId);
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="@($"new_del_{d.Id}")" checked="@isChecked" @onchange="@(e => SetDeliverySupplier(deliveryId, (bool)(e.Value ?? false)))" />
                                <label class="form-check-label small" for="@($"new_del_{d.Id}")">@d.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Observações</div>
                <div class="card-body py-2">
                    <InputTextArea class="form-control form-control-sm" @bind-Value="_model.Obs" rows="2" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary @(_submitAttemptedWithErrors ? "btn-submit-has-errors" : null)" disabled="@_saving">@(_saving ? "Criando..." : _submitAttemptedWithErrors ? "Criar fornecedor — Corrija os erros acima" : "Criar fornecedor")</button>
        </EditForm>
    </div>
</div>

@code {
    private SupplierCreateDto _model = new();
    private IReadOnlyList<IdNameDto> _groups = new List<IdNameDto>();
    private int? _payTermInt;
    private int? _stockDaysInt;
    private IReadOnlyList<IdNameDto> _states = new List<IdNameDto>();
    private IReadOnlyList<IdNameDto> _banks = new List<IdNameDto>();
    private IReadOnlyList<IdNameDto> _paymentMethods = new List<IdNameDto>();
    private IReadOnlyList<IdNameDto> _deliverySuppliers = new List<IdNameDto>();
    private bool _showSuccessModal;
    private bool _showPaymentPlanHelp;
    private string _successModalMessage = "";
    private string? _errorMessage;
    private bool _saving;
    private bool _submitAttemptedWithErrors;

    [Inject] private ISupplierService SupplierService { get; set; } = null!;
    [Inject] private ISupplierReferenceService ReferenceService { get; set; } = null!;
    [Inject] private IConfiguration Configuration { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _groups = await ReferenceService.GetSupplierGroupsAsync();
        _states = await ReferenceService.GetStatesAsync();
        _banks = await ReferenceService.GetBanksAsync();
        _paymentMethods = await ReferenceService.GetPaymentMethodsAsync();
        _deliverySuppliers = await ReferenceService.GetDeliverySuppliersAsync();
        if (_groups.Count > 1)
            _model.SupplierGroupId = _groups.First(g => g.Id > 0).Id;
    }

    private void SetDeliverySupplier(int id, bool selected)
    {
        if (selected && !_model.DeliverySupplierIds.Contains(id))
            _model.DeliverySupplierIds.Add(id);
        else if (!selected)
            _model.DeliverySupplierIds.Remove(id);
    }

    private void SetPayTermFromChange(ChangeEventArgs e)
    {
        var s = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(s)) { _payTermInt = null; _model.PayTerm = null; }
        else if (int.TryParse(s, out var n)) { _payTermInt = Math.Clamp(n, 0, 255); _model.PayTerm = (byte)_payTermInt.Value; }
        StateHasChanged();
    }

    private void SetStockDaysFromChange(ChangeEventArgs e)
    {
        var s = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(s)) { _stockDaysInt = null; _model.StockDays = null; }
        else if (int.TryParse(s, out var n)) { _stockDaysInt = Math.Clamp(n, 0, 255); _model.StockDays = (byte)_stockDaysInt.Value; }
        StateHasChanged();
    }

    private void HideSuccessModal() => _showSuccessModal = false;
    private void ShowPaymentPlanHelp() { _showPaymentPlanHelp = true; }
    private void HidePaymentPlanHelp() => _showPaymentPlanHelp = false;

    private void OnSubmitWithErrors() { _submitAttemptedWithErrors = true; StateHasChanged(); }

    private async Task Create()
    {
        _submitAttemptedWithErrors = false;
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_model.AddressCityName) || _model.AddressStateId == 0)
        {
            _errorMessage = "Informe o CEP e aguarde o preenchimento do endereço.";
            return;
        }

        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "SYS";
        var applicationId = Configuration["Authentication:ApplicationName"] ?? "EUROERP";

        _saving = true;
        try
        {
            var newId = await SupplierService.CreateAsync(_model, applicationId, userId);
            _successModalMessage = $"Fornecedor {newId} criado com sucesso.";
            _showSuccessModal = true;
            _model = new SupplierCreateDto();
            _payTermInt = null;
            _stockDaysInt = null;
            await LoadReferences();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task LoadReferences()
    {
        _groups = await ReferenceService.GetSupplierGroupsAsync();
        _states = await ReferenceService.GetStatesAsync();
        _banks = await ReferenceService.GetBanksAsync();
        _paymentMethods = await ReferenceService.GetPaymentMethodsAsync();
        _deliverySuppliers = await ReferenceService.GetDeliverySuppliersAsync();
        if (_groups.Count > 1)
            _model.SupplierGroupId = _groups.First(g => g.Id > 0).Id;
    }
}
