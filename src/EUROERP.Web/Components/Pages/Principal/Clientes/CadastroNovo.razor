@page "/principal/clientes/cadastro/novo"
@using EUROERP.Application.Address
@using EUROERP.Application.Clients
@using EUROERP.Application.Products
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<PageTitle>Novo Cliente</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Novo Cliente</h5>
    <a class="btn btn-outline-secondary btn-sm" href="/principal/clientes/cadastro">Voltar à lista</a>
</div>

<SuccessModal Show="_showSuccessModal" Message="@_successModalMessage" OnClosed="HideSuccessModal" />

<div class="card">
    <div class="card-body">
        @if (!string.IsNullOrEmpty(_errorMessage)) { <div class="alert alert-danger">@_errorMessage</div> }

        <EditForm Model="_model" OnValidSubmit="Create" OnInvalidSubmit="OnSubmitWithErrors" FormName="newClient">
            <DataAnnotationsValidator />

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Identificação</div>
                <div class="card-body py-2">
                    <div class="row g-2 mb-2">
                        <div class="col-md-2">
                            <label class="form-label">Tipo</label>
                            <select class="form-select form-select-sm" @bind="_model.PersonType">
                                <option value="F">Pessoa Física</option>
                                <option value="J">Pessoa Jurídica</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">CNPJ/CPF <span class="text-danger">*</span></label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Cnpjpf" />
                            <ValidationMessage For="@(() => _model.Cnpjpf)" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Insc. Estadual</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.StateInscr" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Nome / Razão Social <span class="text-danger">*</span></label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.SocialName" />
                            <ValidationMessage For="@(() => _model.SocialName)" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Nome Fantasia</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.FantasyName" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Mercado</label>
                            <select class="form-select form-select-sm" @bind="_model.MarketId">
                                @foreach (var m in _markets.Where(x => x.Id > 0))
                                {
                                    <option value="@m.Id">@m.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Contato</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Contact" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Endereço</div>
                <div class="card-body py-2">
                    <AddressByCep @bind-AddressStreet="_model.AddressStreet"
                                 @bind-AddressNumber="_model.AddressNumber"
                                 @bind-AddressComplement="_model.AddressComplement"
                                 @bind-AddressBlock="_model.AddressBlock"
                                 @bind-AddressZipCode="_model.AddressZipCode"
                                 @bind-AddressStateId="_model.AddressStateId"
                                 @bind-AddressCityName="_model.AddressCityName"
                                 @bind-AddressCityIbge="_model.AddressCityIbge"
                                 States="_states" ValidationForCep="@(() => _model.AddressZipCode)" />
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Contato</div>
                <div class="card-body py-2">
                    <div class="row g-2 mb-2">
                        <div class="col-md-3">
                            <label class="form-label">Telefone 1</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Phone1" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Telefone 2</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Phone2" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Telefone 3</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Phone3" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Celular</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Celular" />
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-md-4">
                            <label class="form-label">E-mail</label>
                            <InputText class="form-control form-control-sm" @bind-Value="_model.Email" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Comercial</div>
                <div class="card-body py-2">
                    <div class="row g-2 mb-2">
                        <div class="col-md-2">
                            <label class="form-label">Modo pagto. 1</label>
                            <select class="form-select form-select-sm" @bind="_model.PaymentMethodId">
                                @foreach (var pm in _paymentMethods)
                                {
                                    <option value="@(pm.Id == 0 ? (byte?)null : (byte)pm.Id)">@pm.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Modo pagto. 2</label>
                            <select class="form-select form-select-sm" @bind="_model.PaymentMethodId2">
                                @foreach (var pm in _paymentMethods)
                                {
                                    <option value="@(pm.Id == 0 ? (byte?)null : (byte)pm.Id)">@pm.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Modo pagto. 3</label>
                            <select class="form-select form-select-sm" @bind="_model.PaymentMethodId3">
                                @foreach (var pm in _paymentMethods)
                                {
                                    <option value="@(pm.Id == 0 ? (byte?)null : (byte)pm.Id)">@pm.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Prazo médio</label>
                            <input type="number" min="0" max="255" class="form-control form-control-sm" value="@_avgPayTermInt" @onchange="@(e => SetAvgPayTermFromChange(e))" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Limite</label>
                            <InputNumber class="form-control form-control-sm" @bind-Value="_model.LimitAmount" />
                        </div>
                        <div class="col-md-1">
                            <label class="form-label">Dia aniv.</label>
                            <input type="number" min="0" max="31" class="form-control form-control-sm" @bind="_model.Birthday" />
                        </div>
                        <div class="col-md-1">
                            <label class="form-label">Mês aniv.</label>
                            <input type="number" min="0" max="12" class="form-control form-control-sm" @bind="_model.BirthMonth" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Endereço de cobrança</div>
                <div class="card-body py-2">
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" id="new_bill_same" checked="@(_model.BillAddressIndicator == "Y")" @onchange="@(e => ToggleBillSame(e))" />
                        <label class="form-check-label" for="new_bill_same">Igual ao endereço acima</label>
                    </div>
                    @if (_model.BillAddressIndicator != "Y")
                    {
                        <div class="row g-2 mb-2">
                            <div class="col-md-4">
                                <label class="form-label">Rua</label>
                                <InputText class="form-control form-control-sm" @bind-Value="_model.BillAddressStreet" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Bairro</label>
                                <InputText class="form-control form-control-sm" @bind-Value="_model.BillAddressBlock" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Número</label>
                                <InputNumber class="form-control form-control-sm" @bind-Value="_model.BillAddressNumber" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">CEP</label>
                                <InputText class="form-control form-control-sm" @bind-Value="_model.BillAddressZipCode" />
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Transportadoras</div>
                <div class="card-body py-2">
                    <div class="border rounded p-2" style="max-height: 150px; overflow-y: auto;">
                        @foreach (var d in _deliverySuppliers.Where(x => x.Id > 0))
                        {
                            var deliveryId = d.Id;
                            var isChecked = _model.DeliverySupplierIds.Contains(deliveryId);
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="@($"new_del_{d.Id}")" checked="@isChecked" @onchange="@(e => SetDeliverySupplier(deliveryId, (bool)(e.Value ?? false)))" />
                                <label class="form-check-label small" for="@($"new_del_{d.Id}")">@d.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Vendedores</div>
                <div class="card-body py-2">
                    <div class="border rounded p-2" style="max-height: 150px; overflow-y: auto;">
                        @foreach (var s in _salesAgents)
                        {
                            var uid = s.Id;
                            var isChecked = _model.SalesAgentIds.Contains(uid);
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="@($"new_sales_{uid}")" checked="@isChecked" @onchange="@(e => SetSalesAgent(uid, (bool)(e.Value ?? false)))" />
                                <label class="form-check-label small" for="@($"new_sales_{uid}")">@s.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 small fw-semibold">Observações</div>
                <div class="card-body py-2">
                    <InputTextArea class="form-control form-control-sm" @bind-Value="_model.Obs" rows="2" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary @(_submitAttemptedWithErrors ? "btn-submit-has-errors" : null)" disabled="@_saving">@(_saving ? "Criando..." : _submitAttemptedWithErrors ? "Criar cliente — Corrija os erros acima" : "Criar cliente")</button>
        </EditForm>
    </div>
</div>

@code {
    private ClientCreateDto _model = new();
    private IReadOnlyList<IdNameDto> _markets = new List<IdNameDto>();
    private int? _avgPayTermInt;
    private IReadOnlyList<IdNameDto> _states = new List<IdNameDto>();
    private IReadOnlyList<PaymentMethodRefDto> _paymentMethods = new List<PaymentMethodRefDto>();
    private IReadOnlyList<IdNameDto> _deliverySuppliers = new List<IdNameDto>();
    private IReadOnlyList<UserIdNameDto> _salesAgents = new List<UserIdNameDto>();
    private bool _showSuccessModal;
    private string _successModalMessage = "";
    private string? _errorMessage;
    private bool _saving;
    private bool _submitAttemptedWithErrors;

    [Inject] private IClientService ClientService { get; set; } = null!;
    [Inject] private IClientReferenceService ReferenceService { get; set; } = null!;
    [Inject] private IConfiguration Configuration { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _markets = await ReferenceService.GetMarketsAsync();
        _states = await ReferenceService.GetStatesAsync(1);
        _paymentMethods = await ReferenceService.GetPaymentMethodsAsync();
        _deliverySuppliers = await ReferenceService.GetDeliverySuppliersAsync();
        _salesAgents = await ReferenceService.GetSalesAgentsAsync();
        if (_markets.Count > 1)
            _model.MarketId = (byte)_markets.First(m => m.Id > 0).Id;
    }

    private void SetAvgPayTermFromChange(ChangeEventArgs e)
    {
        var s = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(s)) { _avgPayTermInt = null; _model.AvgPayTerm = null; }
        else if (int.TryParse(s, out var n)) { _avgPayTermInt = Math.Clamp(n, 0, 255); _model.AvgPayTerm = (byte)_avgPayTermInt.Value; }
        StateHasChanged();
    }

    private void ToggleBillSame(ChangeEventArgs e)
    {
        _model.BillAddressIndicator = (bool)(e.Value ?? false) ? "Y" : "N";
        StateHasChanged();
    }

    private void SetDeliverySupplier(int id, bool selected)
    {
        if (selected && !_model.DeliverySupplierIds.Contains(id))
            _model.DeliverySupplierIds.Add(id);
        else if (!selected)
            _model.DeliverySupplierIds.Remove(id);
    }

    private void SetSalesAgent(string userId, bool selected)
    {
        if (selected && !_model.SalesAgentIds.Contains(userId))
            _model.SalesAgentIds.Add(userId);
        else if (!selected)
            _model.SalesAgentIds.Remove(userId);
    }

    private void HideSuccessModal() => _showSuccessModal = false;
    private void OnSubmitWithErrors() { _submitAttemptedWithErrors = true; StateHasChanged(); }

    private async Task Create()
    {
        _submitAttemptedWithErrors = false;
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_model.AddressCityName) || _model.AddressStateId == 0)
        {
            _errorMessage = "Informe o CEP e aguarde o preenchimento do endereço.";
            return;
        }

        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "SYS";
        var applicationId = Configuration["Authentication:ApplicationName"] ?? "EUROERP";

        _saving = true;
        try
        {
            var newId = await ClientService.CreateAsync(_model, applicationId, userId);
            _successModalMessage = $"Cliente {newId} criado com sucesso.";
            _showSuccessModal = true;
            _model = new ClientCreateDto();
            _avgPayTermInt = null;
            await LoadReferences();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task LoadReferences()
    {
        _markets = await ReferenceService.GetMarketsAsync();
        _states = await ReferenceService.GetStatesAsync(1);
        _paymentMethods = await ReferenceService.GetPaymentMethodsAsync();
        _deliverySuppliers = await ReferenceService.GetDeliverySuppliersAsync();
        _salesAgents = await ReferenceService.GetSalesAgentsAsync();
        if (_markets.Count > 1)
            _model.MarketId = (byte)_markets.First(m => m.Id > 0).Id;
    }
}
