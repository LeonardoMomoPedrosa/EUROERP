@page "/principal/estoque/ativos-classe/imprimir"
@layout PrintLayout
@using EUROERP.Application.Stock
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<PageTitle>Rel. Ativos — Impressão</PageTitle>

<div class="no-print mb-3 d-flex gap-2 align-items-center">
    <button type="button" class="btn btn-primary btn-sm" onclick="window.print()">&#128438; Imprimir</button>
    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.close()">Fechar</button>
    @if (_result.Rows.Count > 0)
    {
        <span class="text-muted small ms-2">@_result.Rows.Count registro(s)</span>
    }
</div>

@if (_loading)
{
    <p class="text-muted">Carregando...</p>
}
else if (_error != null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div style="font-size: .8rem;">

        <div style="display:flex; align-items:center; justify-content:space-between; border-bottom:2px solid #dee2e6; padding-bottom:.5rem; margin-bottom:.75rem;">
            <img src="/images/mailogo.jpg" alt="Logo" style="max-height:56px; max-width:180px; object-fit:contain;" />
            <div style="text-align:right; line-height:1.3;">
                <div style="font-size:1rem; font-weight:700;">Relatório de Ativos</div>
                <div style="font-size:.8rem; color:#6c757d;">Visão: @_viewModeLabel</div>
                @if (!string.IsNullOrWhiteSpace(_result.Breadcrumb))
                {
                    <div style="font-size:.8rem; color:#6c757d;">@_result.Breadcrumb</div>
                }
            </div>
        </div>

        <table class="table table-sm table-bordered mb-0" style="font-size: inherit;">
            <thead class="table-light">
                <tr>
                    <th>@(_filter.DrillLevel == 0 ? "Grupo" : "Produto")</th>
                    <th>Classe</th>
                    <th class="text-end">Estoque</th>
                    <th class="text-end">Total custo</th>
                    <th class="text-end">Total venda</th>
                    <th class="text-end">Margem %</th>
                    @if (_filter.DrillLevel > 0)
                    {
                        <th class="text-end">q1</th>
                        <th class="text-end">q2</th>
                        <th class="text-end">q3</th>
                        <th class="text-end">q4</th>
                        <th class="text-end">q5</th>
                        <th class="text-end">q6</th>
                        <th class="text-end">q7</th>
                        <th class="text-end">q8</th>
                        <th class="text-end">q9</th>
                        <th class="text-end">q10</th>
                        <th class="text-end">qm</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (_result.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="@GetGridColumnCount()" class="text-center text-muted py-2">Nenhum ativo encontrado.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in _result.Rows)
                    {
                        <tr>
                            <td>@row.Description</td>
                            <td>@(row.ClassName ?? "—")</td>
                            <td class="text-end">@row.Stock</td>
                            <td class="text-end">@FormatMoney(row.TotalCost)</td>
                            <td class="text-end">@FormatMoney(row.TotalPrice)</td>
                            <td class="text-end">@row.MarginPercent.ToString("N2", _ptBr)</td>
                            @if (_filter.DrillLevel > 0)
                            {
                                <td class="text-end">@row.Q1</td>
                                <td class="text-end">@row.Q2</td>
                                <td class="text-end">@row.Q3</td>
                                <td class="text-end">@row.Q4</td>
                                <td class="text-end">@row.Q5</td>
                                <td class="text-end">@row.Q6</td>
                                <td class="text-end">@row.Q7</td>
                                <td class="text-end">@row.Q8</td>
                                <td class="text-end">@row.Q9</td>
                                <td class="text-end">@row.Q10</td>
                                <td class="text-end">@row.Qm.ToString("N0", _ptBr)</td>
                            }
                        </tr>
                    }
                }
            </tbody>
            @if (_result.Rows.Count > 0)
            {
                <tfoot class="table-light">
                    <tr>
                        <th>Total</th>
                        <th></th>
                        <th class="text-end">@_result.TotalStock.ToString("N0", _ptBr)</th>
                        <th class="text-end">@FormatMoney(_result.TotalCost)</th>
                        <th class="text-end">@FormatMoney(_result.TotalPrice)</th>
                        <th></th>
                        @if (_filter.DrillLevel > 0)
                        {
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                            <th></th>
                        }
                    </tr>
                </tfoot>
            }
        </table>
    </div>
}

@code {
    private static readonly System.Globalization.CultureInfo _ptBr = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    private StockAssetsFilterDto _filter = new();
    private StockAssetsResultDto _result = new();
    private bool _loading = true;
    private string? _error;
    private string? _viewModeLabel;
    private bool _printed;

    [Inject] private IStockAssetsReportService StockAssetsReportService { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var q = ParseQueryString(uri.Query);

        _filter.ViewMode = StockAssetsViewMode.Products;
        _viewModeLabel = "Produto";

        if (!int.TryParse(q.GetValueOrDefault("dl"), out var drillLevel) || drillLevel < 0 || drillLevel > 1)
            drillLevel = 0;
        _filter.DrillLevel = drillLevel;

        if (byte.TryParse(q.GetValueOrDefault("ci"), out var classId))
            _filter.ClassId = classId;
        if (byte.TryParse(q.GetValueOrDefault("gi"), out var groupId))
            _filter.GroupId = groupId;

        _loading = true;
        try
        {
            _result = await StockAssetsReportService.SearchAsync(_filter);
        }
        catch (Exception ex)
        {
            _error = "Erro ao carregar relatório: " + ex.Message;
            _result = new StockAssetsResultDto();
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_printed || _loading || _error != null)
            return;

        _printed = true;
        await JSRuntime.InvokeVoidAsync("window.print");
    }

    private static string FormatMoney(decimal value) => $"R$ {value:N2}";

    private int GetGridColumnCount() => _filter.DrillLevel > 0 ? 17 : 6;

    private static Dictionary<string, string> ParseQueryString(string query)
    {
        var d = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(query)) return d;
        foreach (var part in query.TrimStart('?').Split('&'))
        {
            var kv = part.Split('=', 2, StringSplitOptions.None);
            if (kv.Length == 2 && !string.IsNullOrEmpty(kv[0]))
                d[kv[0].Trim()] = Uri.UnescapeDataString(kv[1].Trim());
        }
        return d;
    }
}
