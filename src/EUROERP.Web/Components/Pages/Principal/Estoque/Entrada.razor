@page "/principal/estoque/entrada"
@using EUROERP.Application.Stock
@using EUROERP.Application.Products
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<PageTitle>Estoque - Entrada</PageTitle>

<style>
    .entrada-compact .card-body { padding: 0.5rem 1rem; }
    .entrada-compact .card-header { padding: 0.35rem 0.75rem; }
    .entrada-compact .card-header h5 { font-size: 1rem; }
    .entrada-compact p { margin-bottom: 0.25rem; }
    .entrada-compact .row.g-2 { margin-bottom: 0.4rem; }
    .entrada-compact .form-label { margin-bottom: 0.15rem; font-size: 0.8rem; }
    .entrada-compact .table th,
    .entrada-compact .table td { padding: 0.2rem 0.4rem; }
    .entrada-compact .table-responsive .py-3 { padding-top: 0.4rem !important; padding-bottom: 0.4rem !important; }
    .entrada-compact .mb-2 { margin-bottom: 0.35rem !important; }
    .entrada-compact .mb-3 { margin-bottom: 0.5rem !important; }
    .entrada-compact .mt-3 { margin-top: 0.5rem !important; }
    .entrada-compact .grid-card .card-body { padding: 0; }
    .entrada-compact .d-flex.gap-2 { gap: 0.35rem !important; }
</style>

<div class="entrada-compact">
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Entrada de Estoque — Etapa @_step de 4</h5>
        @if (_step > 1)
        {
            <span class="badge bg-secondary">@StepTitle</span>
        }
    </div>
    <div class="card-body">
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        @if (_step == 1)
        {
            <p class="text-muted small mb-2">Busque e selecione o fornecedor.</p>
            <div class="row g-2 mb-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label">Nome do fornecedor</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Razão social..."
                           @bind="_supplierNameFilter" @bind:event="oninput" />
                </div>
                <div class="col-md-auto">
                    <button type="button" class="btn btn-primary btn-sm" @onclick="BuscarFornecedores" disabled="@_loading">@(_loading ? "Buscando..." : "Buscar")</button>
                </div>
            </div>
            <div class="card grid-card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-0 data-grid-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Id</th>
                                    <th>Razão Social</th>
                                    <th>CNPJ/CPF</th>
                                    <th>Cidade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_loading && _suppliers.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-3">Carregando...</td></tr>
                                }
                                else if (_suppliers.Count == 0)
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-3">Nenhum fornecedor encontrado.</td></tr>
                                }
                                else
                                {
                                    @foreach (var s in _suppliers)
                                    {
                                        <tr role="button" class="@(_selectedSupplier?.Id == s.Id ? "table-primary" : "")" @onclick="() => SelecionarFornecedor(s)">
                                            <td>@s.Id</td>
                                            <td>@s.SocialName</td>
                                            <td>@(s.Cnpj ?? "-")</td>
                                            <td>@(s.City ?? "-")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (_step == 2)
        {
            <p class="mb-2"><strong>Fornecedor:</strong> @_selectedSupplier?.SocialName</p>
            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <label class="form-label">Número da Fatura do Fornecedor <span class="text-danger">*</span></label>
                    <input type="text" class="form-control form-control-sm" @bind="_externalPkid" maxlength="30" placeholder="Ex.: NF-001" />
                </div>
                <div class="col-md-2 d-flex align-items-end pb-1">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="nfeInd" @bind="_nfeInd" />
                        <label class="form-check-label small" for="nfeInd">Entrada de NF</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Valor da NFE (R$)</label>
                    <input type="number" class="form-control form-control-sm text-end" @bind="_nfeAmount" step="0.01" disabled="@(!_nfeInd)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Frete (R$)</label>
                    <input type="number" class="form-control form-control-sm text-end" @bind="_shipCost" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Crédito (R$)</label>
                    <input type="number" class="form-control form-control-sm text-end" @bind="_creditAmount" step="0.01" />
                </div>
            </div>
            <div class="row g-2 mb-2">
                <div class="col-md-2">
                    <label class="form-label">II (R$)</label>
                    <input type="number" class="form-control form-control-sm text-end" @bind="_iiCost" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">ICMS (R$)</label>
                    <input type="number" class="form-control form-control-sm text-end" @bind="_icmsCost" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">PIS (R$)</label>
                    <input type="number" class="form-control form-control-sm text-end" @bind="_pisCost" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">COFINS (R$)</label>
                    <input type="number" class="form-control form-control-sm text-end" @bind="_cofinsCost" step="0.01" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <p class="mb-0 small text-muted">Total rateio: <strong>R$ @GetProrateTotal().ToString("N2")</strong></p>
                </div>
            </div>
        }

        @if (_step == 3)
        {
            <p class="mb-2"><strong>Fornecedor:</strong> @_header?.SupplierName — Fatura: @_header?.ExternalPkid</p>
            <div class="row g-2 mb-2">
                <div class="col-md-4">
                    <p class="mb-0 small"><b>Total Rateio:</b> R$ @(_header?.ProrateTotal.ToString("N2") ?? "0,00")</p>
                </div>
                <div class="col-md-4">
                    <p class="mb-0 small"><b>Custo Total:</b> R$ @_details.Sum(d => d.TotalCost).ToString("N2")</p>
                </div>
            </div>
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Digite as mercadorias (nome ou código)</label>
                    <div class="position-relative autocomplete-wrapper">
                        <input type="text" class="form-control form-control-sm"
                               placeholder="Mín. 2 caracteres..."
                               value="@_productTerm"
                               @oninput="OnProductInput"
                               @onblur="OnProductBlur"
                               @onfocus="OnProductFocus"
                               autocomplete="off" />
                        @if (_loadingProductSuggestions)
                        {
                            <span class="position-absolute top-50 end-0 translate-middle-y pe-2 small text-muted">...</span>
                        }
                        @if (_showProductSuggestions)
                        {
                            <div class="supplier-autocomplete-dropdown position-absolute start-0 end-0 top-100 mt-1 border rounded bg-white shadow-sm border-dark" style="z-index: 9999; max-height: min(55vh, 450px); overflow-y: auto; min-height: 2rem;" @onmousedown="OnProductDropdownMouseDown" @onmousedown:preventDefault>
                                @if (_loadingProductSuggestions)
                                {
                                    <div class="p-2 small text-muted">Carregando...</div>
                                }
                                else if (_productSuggestions.Count == 0)
                                {
                                    <div class="p-2 small text-muted">Nenhum produto encontrado.</div>
                                }
                                else
                                {
                                    @foreach (var p in _productSuggestions)
                                    {
                                        <div class="supplier-autocomplete-item px-2 py-1 small cursor-pointer" @onmousedown="() => SelectProduct(p)" @onmousedown:preventDefault>
                                            <span class="fw-semibold">@p.Name</span>
                                            @if (!string.IsNullOrEmpty(p.ExternalPkid))
                                            {
                                                <span class="text-muted"> — @p.ExternalPkid</span>
                                            }
                                            <span class="text-muted"> Custo: R$ @p.CostGross.ToString("N2")</span>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (_selectedProductForAdd != null)
            {
                <div class="card mb-3 border-primary">
                    <div class="card-body py-2">
                        <p class="mb-2 small"><strong>Produto:</strong> @_selectedProductForAdd.Name @(string.IsNullOrEmpty(_selectedProductForAdd.ExternalPkid) ? "" : $"({_selectedProductForAdd.ExternalPkid})") — Saldo: @_selectedProductForAdd.Stock</p>
                        <div class="d-flex flex-wrap gap-2 align-items-end">
                            <div style="width: 5rem;">
                                <label class="form-label small mb-0">CSTB</label>
                                <select class="form-select form-select-sm" style="width: 5rem;" @bind="_addCstbId">
                                    @foreach (var c in _cstb)
                                    {
                                        <option value="@c.Id.ToString()">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div style="width: 4.2rem;">
                                <label class="form-label small mb-0">C.bruto</label>
                                <input type="number" class="form-control form-control-sm text-end" style="width: 4.2rem;" @bind="_addUnitCostGross" @bind:event="oninput" @bind:after="RecalcAddPriceFromCost" step="0.01" />
                            </div>
                            <div style="width: 3.5rem;">
                                <label class="form-label small mb-0">IPI %</label>
                                <input type="number" class="form-control form-control-sm text-end" style="width: 3.5rem;" @bind="_addIpi" @bind:event="oninput" @bind:after="RecalcAddPriceFromCost" step="0.01" />
                            </div>
                            <div style="width: 3.5rem;">
                                <label class="form-label small mb-0">Desc.%</label>
                                <input type="number" class="form-control form-control-sm text-end" style="width: 3.5rem;" @bind="_addDiscount" @bind:event="oninput" @bind:after="RecalcAddPriceFromCost" step="0.01" />
                            </div>
                            <div style="width: 4rem;">
                                <label class="form-label small mb-0">C.liq.</label>
                                <input type="text" class="form-control form-control-sm text-end bg-light" style="width: 4rem;" readonly value="@FormatDecimal(GetAddCostLiquid())" />
                            </div>
                            <div style="width: 3.5rem;">
                                <label class="form-label small mb-0">C.transp.</label>
                                <input type="number" class="form-control form-control-sm text-end" style="width: 3.5rem;" @bind="_addCostTransport" @bind:event="oninput" @bind:after="RecalcAddPriceFromCost" step="0.01" />
                            </div>
                            <div style="width: 4rem;">
                                <label class="form-label small mb-0">C.final</label>
                                <input type="text" class="form-control form-control-sm text-end bg-light" style="width: 4rem;" readonly value="@FormatDecimal(GetAddCostFinal())" />
                            </div>
                            <div style="width: 5.5rem;">
                                <label class="form-label small mb-0">Lucro %</label>
                                <input type="number" class="form-control form-control-sm text-end" style="width: 5.5rem;" @bind="_addProfit" @bind:event="oninput" @bind:after="RecalcAddPriceFromProfit" @onchange="RoundAddProfitTo4Decimals" step="0.0001" />
                            </div>
                            <div style="width: 4.2rem;">
                                <label class="form-label small mb-0">Preço</label>
                                <input type="number" class="form-control form-control-sm text-end" style="width: 4.2rem;" @bind="_addPrice" @bind:event="oninput" @bind:after="RecalcAddProfitFromPrice" @onchange="RoundAddPriceTo2Decimals" step="0.01" />
                            </div>
                            <div style="width: 4rem;">
                                <label class="form-label small mb-0">Qtd</label>
                                <input type="number" class="form-control form-control-sm text-end" style="width: 4rem;" @bind="_addQty" min="0.001" step="0.001" />
                            </div>
                            <div class="d-flex gap-1 align-items-end">
                                <button type="button" class="btn btn-success btn-sm" @onclick="AdicionarItem" disabled="@(_addQty <= 0 || _adding)">@(_adding ? "..." : "Adicionar")</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CancelarProduto">Cancelar</button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted small">Itens no carrinho</span>
                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="LimparTudo" disabled="@(_details.Count == 0 || _clearing)">Limpar Tudo</button>
            </div>
            <div class="card grid-card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-0 data-grid-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Produto</th>
                                    <th>Qtd</th>
                                    <th>Custo unit.</th>
                                    <th>IPI %</th>
                                    <th>Desc.%</th>
                                    <th>C.liq.</th>
                                    <th>Transp.</th>
                                    <th>C.final</th>
                                    <th>Custo total</th>
                                    <th>Lucro %</th>
                                    <th>Preço unit.</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_details.Count == 0)
                                {
                                    <tr><td colspan="12" class="text-center text-muted py-3">Nenhum item. Use o campo acima para adicionar produtos.</td></tr>
                                }
                                else
                                {
                                    @foreach (var d in _details)
                                    {
                                        <tr>
                                            <td>@d.ProductName @(string.IsNullOrEmpty(d.ExternalId) ? "" : $"({d.ExternalId})")</td>
                                            <td>@d.Quantity.ToString("0.###")</td>
                                            <td class="text-end">@d.UnitCostGross.ToString("N2")</td>
                                            <td class="text-end">@d.Ipi.ToString("N1")</td>
                                            <td class="text-end">@d.Discount.ToString("N1")%</td>
                                            <td class="text-end">@d.UnitCostNet.ToString("N2")</td>
                                            <td class="text-end">@d.CostTransport.ToString("N4")</td>
                                            <td class="text-end">@d.UnitCostFinal.ToString("N2")</td>
                                            <td class="text-end">@d.TotalCost.ToString("N2")</td>
                                            <td class="text-end">@FormatProfitPercent(d.Profit)%</td>
                                            <td class="text-end">@d.UnitMarketPrice.ToString("N2")</td>
                                            <td>
                                                <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => RemoverItem(d.ProductId)" title="Remover">×</button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (_step == 4)
        {
            <p class="mb-2"><strong>Fornecedor:</strong> @_header?.SupplierName — Fatura: @_header?.ExternalPkid</p>
            <p class="mb-1">Total de itens: <strong>@_details.Count</strong></p>
            <p class="fs-5 mb-0">Total calculado: <strong class="text-success">R$ @_totalCalculado.ToString("N2")</strong></p>
            <p class="text-muted small mt-1">Clique em <strong>Finalizar</strong> para efetivar a entrada de estoque (atualização de saldos e custos dos produtos).</p>
        }

        <div class="mt-3 d-flex gap-2">
            @if (_step > 1)
            {
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Voltar">Voltar</button>
            }
            @if (_step < 4)
            {
                <button type="button" class="btn btn-primary btn-sm" @onclick="Continuar" disabled="@((_step == 1 && _selectedSupplier == null) || (_step == 2 && string.IsNullOrWhiteSpace(_externalPkid)) || _loading)">
                    @(_loading ? "Aguarde..." : "Continuar")
                </button>
            }
            @if (_step == 4)
            {
                <button type="button" class="btn btn-success btn-sm" @onclick="Finalizar" disabled="@_finalizing">@(_finalizing ? "Finalizando..." : "Finalizar")</button>
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Cancelar">Cancelar</button>
        </div>
    </div>
</div>
</div>

<SuccessModal Show="_showSuccessModal" Message="Entrada de estoque finalizada com sucesso." OnClosed="HideSuccessModal" />

@code {
    private int _step = 1;
    private string? _supplierNameFilter;
    private IReadOnlyList<StockInSupplierDto> _suppliers = new List<StockInSupplierDto>();
    private StockInSupplierDto? _selectedSupplier;
    private string _externalPkid = "";
    private decimal? _shipCost;
    private decimal? _iiCost;
    private decimal? _icmsCost;
    private decimal? _pisCost;
    private decimal? _cofinsCost;
    private decimal? _creditAmount;
    private bool _nfeInd;
    private decimal? _nfeAmount;
    private int? _stockInId;
    private StockInHeaderDto? _header;
    private List<StockInDetailItemDto> _details = new();
    private decimal _totalCalculado;
    private string? _errorMessage;
    private bool _loading;
    private bool _adding;
    private bool _clearing;
    private bool _finalizing;
    private bool _showSuccessModal;

    private string _productTerm = "";
    private IReadOnlyList<StockInProductSearchDto> _productSuggestions = new List<StockInProductSearchDto>();
    private bool _showProductSuggestions;
    private bool _loadingProductSuggestions;
    private bool _selectingProduct;
    private StockInProductSearchDto? _selectedProductForAdd;
    private decimal _addQty = 1m;
    private decimal _addUnitCostGross;
    private decimal _addIpi;
    private decimal _addDiscount;
    private decimal _addCostTransport = 1m;
    private decimal _addProfit;
    private decimal _addPrice;
    private string? _addCstbId;
    private IReadOnlyList<IdNameDto> _cstb = new List<IdNameDto>();
    private readonly Dictionary<int, string> _cstbByProduct = new();
    private CancellationTokenSource? _productDebounceCts;

    [Inject] private IStockInService StockInService { get; set; } = null!;
    [Inject] private IProductReferenceService ReferenceService { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] private IConfiguration Configuration { get; set; } = null!;
        
    private string StepTitle => _step switch
    {
        1 => "Fornecedor",
        2 => "Dados gerais",
        3 => "Produtos",
        4 => "Verificação",
        _ => ""
    };

    protected override async Task OnInitializedAsync()
    {
        _cstb = await ReferenceService.GetCstbAsync();
        await BuscarFornecedores();
    }

    private decimal GetProrateTotal() =>
        (_shipCost ?? 0) + (_iiCost ?? 0) + (_icmsCost ?? 0) + (_pisCost ?? 0) + (_cofinsCost ?? 0) - (_creditAmount ?? 0);

    private async Task BuscarFornecedores()
    {
        _errorMessage = null;
        _loading = true;
        try
        {
            _suppliers = await StockInService.GetSuppliersForStockInAsync(_supplierNameFilter);
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao buscar fornecedores: " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelecionarFornecedor(StockInSupplierDto s)
    {
        _selectedSupplier = s;
        _errorMessage = null;
    }

    private void Continuar()
    {
        _errorMessage = null;
        if (_step == 1)
        {
            if (_selectedSupplier == null) return;
            _step = 2;
            _externalPkid = "";
            _shipCost = null;
            _iiCost = null;
            _icmsCost = null;
            _pisCost = null;
            _cofinsCost = null;
            _creditAmount = null;
            _nfeInd = false;
            _nfeAmount = null;
            return;
        }
        if (_step == 2)
        {
            _loading = true;
            _ = ContinuarStep2Async();
            return;
        }
        if (_step == 3)
        {
            _totalCalculado = _details.Sum(d => d.TotalCost);
            _step = 4;
        }
    }

    private async Task ContinuarStep2Async()
    {
        if (_selectedSupplier == null || string.IsNullOrWhiteSpace(_externalPkid))
            return;
        _loading = true;
        _errorMessage = null;
        try
        {
            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = state.User.Identity?.Name ?? "SYS";
            var appId = Configuration["App:ApplicationId"] ?? "EUROERP";
            var header = new StockInHeaderDto
            {
                SupplierId = _selectedSupplier.Id,
                ExternalPkid = _externalPkid.Trim(),
                ShipCost = _shipCost,
                IiCost = _iiCost,
                IcmsCost = _icmsCost,
                PisCost = _pisCost,
                CofinsCost = _cofinsCost,
                CreditAmount = _creditAmount,
                NfeInd = _nfeInd,
                NfeAmount = _nfeInd ? _nfeAmount : 0,
                CurrencyId = 1
            };
            var (id, err) = await StockInService.CreateOrGetStockInAsync(header, userId, appId);
            if (err != null)
            {
                _errorMessage = err;
                return;
            }
            _stockInId = id;
            _header = await StockInService.GetStockInHeaderAsync(id!.Value);
            _details = (await StockInService.GetStockInDetailsAsync(id.Value)).ToList();
            _step = 3;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao criar entrada: " + ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void Voltar()
    {
        _errorMessage = null;
        if (_step == 2) _step = 1;
        else if (_step == 3)
        {
            PopulateStep2FromHeader();
            _step = 2;
        }
        else if (_step == 4) _step = 3;
    }

    private void PopulateStep2FromHeader()
    {
        if (_header == null) return;
        _externalPkid = _header.ExternalPkid;
        _shipCost = _header.ShipCost;
        _iiCost = _header.IiCost;
        _icmsCost = _header.IcmsCost;
        _pisCost = _header.PisCost;
        _cofinsCost = _header.CofinsCost;
        _creditAmount = _header.CreditAmount;
        _nfeInd = _header.NfeInd;
        _nfeAmount = _header.NfeAmount;
    }

    private void Cancelar()
    {
        _step = 1;
        _selectedSupplier = null;
        _stockInId = null;
        _header = null;
        _details.Clear();
        _cstbByProduct.Clear();
        _errorMessage = null;
        _productTerm = "";
        _selectedProductForAdd = null;
        _showProductSuggestions = false;
        BuscarFornecedores();
    }

    private void OnProductInput(ChangeEventArgs e)
    {
        _productTerm = e.Value?.ToString() ?? "";
        _showProductSuggestions = (_productTerm.Trim().Length >= 2);
        _ = DoProductSearchAsync();
    }

    private void OnProductFocus()
    {
        if ((_productTerm?.Trim().Length ?? 0) >= 2)
            _showProductSuggestions = true;
    }

    private void OnProductDropdownMouseDown(MouseEventArgs _) => _selectingProduct = true;

    private async Task DoProductSearchAsync()
    {
        _productDebounceCts?.Cancel();
        _productDebounceCts = new CancellationTokenSource();
        var ct = _productDebounceCts.Token;
        if ((_productTerm?.Trim().Length ?? 0) < 2)
        {
            _productSuggestions = new List<StockInProductSearchDto>();
            StateHasChanged();
            return;
        }
        try { await Task.Delay(300, ct); } catch (TaskCanceledException) { return; }
        _loadingProductSuggestions = true;
        StateHasChanged();
        try
        {
            var list = await StockInService.GetProductSuggestionsAsync(_productTerm!.Trim(), null, 30, ct);
            if (!ct.IsCancellationRequested)
            {
                _productSuggestions = list;
                _showProductSuggestions = true;
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception)
        {
            if (!ct.IsCancellationRequested)
                _productSuggestions = new List<StockInProductSearchDto>();
        }
        finally
        {
            if (!ct.IsCancellationRequested)
            {
                _loadingProductSuggestions = false;
                StateHasChanged();
            }
        }
    }

    private async Task OnProductBlur()
    {
        await Task.Delay(200);
        if (!_selectingProduct)
            _showProductSuggestions = false;
        _selectingProduct = false;
        StateHasChanged();
    }

    private void SelectProduct(StockInProductSearchDto p)
    {
        _selectingProduct = true;
        _showProductSuggestions = false;
        _selectedProductForAdd = p;
        _addQty = 1m;
        _addUnitCostGross = p.CostGross;
        _addIpi = p.Ipi;
        _addDiscount = p.Discount;
        _addCostTransport = p.CostTransport > 0 ? p.CostTransport : 1m;
        _addCstbId = !string.IsNullOrEmpty(p.CstbId) ? p.CstbId : (_cstb.Count > 0 ? _cstb[0].Id.ToString() : null);
        var costLiq = GetCostNet(p.CostGross, p.Ipi, p.Discount);
        if (costLiq <= 0 && p.CostNet > 0) costLiq = p.CostNet;
        var costFinal = costLiq * _addCostTransport;
        _addProfit = costFinal > 0 && p.Price > 0 ? Math.Round(((p.Price / costFinal) - 1m) * 100m, 4) : 0;
        _addPrice = Math.Round(costFinal * (1 + _addProfit / 100m), 2);
        _productTerm = p.Name;
    }

    private static decimal GetCostNet(decimal gross, decimal ipi, decimal discount) =>
        gross * (1 + ipi / 100m) * (1 - discount / 100m);

    private static string FormatDecimal(decimal value) => value.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"));

    /// <summary>Lucro %: até 4 casas decimais.</summary>
    private static string FormatProfitPercent(decimal value) => Math.Round(value, 4).ToString("0.####", System.Globalization.CultureInfo.InvariantCulture);

    /// <summary>Custo líquido = Custo bruto × (1 + IPI/100) × (1 - Desconto % / 100).</summary>
    private decimal GetAddCostLiquid() => GetCostNet(_addUnitCostGross, _addIpi, _addDiscount);

    /// <summary>Custo final = Custo líquido × Custo transporte.</summary>
    private decimal GetAddCostFinal()
    {
        var transport = _addCostTransport > 0 ? _addCostTransport : 1m;
        return GetAddCostLiquid() * transport;
    }

    private void RecalcAddPriceFromCost()
    {
        var costFinal = GetAddCostFinal();
        _addPrice = Math.Round(costFinal * (1 + _addProfit / 100m), 2);
        StateHasChanged();
    }

    private void RecalcAddPriceFromProfit()
    {
        _addPrice = Math.Round(GetAddCostFinal() * (1 + _addProfit / 100m), 2);
        StateHasChanged();
    }

    private void RecalcAddProfitFromPrice()
    {
        var costFinal = GetAddCostFinal();
        _addProfit = costFinal > 0 ? Math.Round(((_addPrice / costFinal) - 1m) * 100m, 4) : 0;
        StateHasChanged();
    }

    private void RoundAddProfitTo4Decimals()
    {
        _addProfit = Math.Round(_addProfit, 4);
        StateHasChanged();
    }

    private void RoundAddPriceTo2Decimals()
    {
        _addPrice = Math.Round(_addPrice, 2);
        StateHasChanged();
    }

    private void CancelarProduto()
    {
        _selectedProductForAdd = null;
        _productTerm = "";
    }

    private async Task AdicionarItem()
    {
        if (_selectedProductForAdd == null || _stockInId == null || _addQty <= 0) return;
        _errorMessage = null;
        _adding = true;
        try
        {
            var costLiq = GetAddCostLiquid();
            var transport = _addCostTransport > 0 ? _addCostTransport : 1m;
            var costFinal = costLiq * transport;
            var detail = new StockInAddDetailDto
            {
                ProductId = _selectedProductForAdd.Id,
                Quantity = _addQty,
                UnitCostGross = _addUnitCostGross > 0 ? _addUnitCostGross : _selectedProductForAdd.CostGross,
                Ipi = _addIpi,
                Discount = _addDiscount,
                CostTransport = transport,
                Profit = Math.Round(_addProfit, 4),
                UnitMarketPrice = _addPrice > 0 ? _addPrice : Math.Round(costFinal * (1 + _addProfit / 100m), 2),
                CstbId = _addCstbId,
                CurrencyId = _selectedProductForAdd.CurrencyId > 0 ? _selectedProductForAdd.CurrencyId : (byte)1
            };
            await StockInService.AddStockInDetailAsync(_stockInId.Value, detail);
            if (!string.IsNullOrEmpty(_addCstbId))
                _cstbByProduct[detail.ProductId] = _addCstbId;
            _details = (await StockInService.GetStockInDetailsAsync(_stockInId.Value)).ToList();
            _header = await StockInService.GetStockInHeaderAsync(_stockInId.Value);
            _selectedProductForAdd = null;
            _productTerm = "";
            _addQty = 1m;
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao adicionar item: " + ex.Message;
        }
        finally
        {
            _adding = false;
        }
    }

    private async Task RemoverItem(int productId)
    {
        if (_stockInId == null) return;
        _errorMessage = null;
        try
        {
            await StockInService.RemoveStockInDetailAsync(_stockInId.Value, productId);
            _cstbByProduct.Remove(productId);
            _details = (await StockInService.GetStockInDetailsAsync(_stockInId.Value)).ToList();
            _header = await StockInService.GetStockInHeaderAsync(_stockInId.Value);
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao remover item: " + ex.Message;
        }
    }

    private async Task LimparTudo()
    {
        if (_stockInId == null) return;
        _errorMessage = null;
        _clearing = true;
        try
        {
            await StockInService.RemoveAllDetailsAsync(_stockInId.Value);
            _details.Clear();
            _cstbByProduct.Clear();
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao limpar: " + ex.Message;
        }
        finally
        {
            _clearing = false;
        }
    }

    private async Task Finalizar()
    {
        if (_stockInId == null) return;
        _errorMessage = null;
        _finalizing = true;
        try
        {
            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = state.User.Identity?.Name ?? "SYS";
            var appId = Configuration["App:ApplicationId"] ?? "EUROERP";
            await StockInService.FinalizeStockInAsync(_stockInId.Value, userId, appId, _cstbByProduct);
            _showSuccessModal = true;
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao finalizar: " + ex.Message;
        }
        finally
        {
            _finalizing = false;
        }
    }

    private void HideSuccessModal()
    {
        _showSuccessModal = false;
        Cancelar();
    }
}
