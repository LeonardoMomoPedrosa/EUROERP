@page "/lista/geral"
@using EUROERP.Application.Products
@rendermode InteractiveServer

<PageTitle>Lista - Geral</PageTitle>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="mb-0">Lista de Produtos</h5>
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">Escolha o tipo de lista, os grupos de produtos e exporte ou visualize.</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-warning py-2">@_error</div>
        }

        <div class="row g-3">
            <div class="col-md-4">
                <fieldset class="border rounded p-2">
                    <legend class="float-none w-auto px-1 fs-6 mb-1">Tipo de lista</legend>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="listMode" id="modePriceAll"
                               checked="@(_mode == ProductListMode.PriceAll)" @onchange="() => SetMode(ProductListMode.PriceAll)" />
                        <label class="form-check-label" for="modePriceAll">Preços — Todo estoque</label>
                    </div>
                    <div class="form-check mt-1">
                        <input class="form-check-input" type="radio" name="listMode" id="modePriceStock"
                               checked="@(_mode == ProductListMode.PriceInStock)" @onchange="() => SetMode(ProductListMode.PriceInStock)" />
                        <label class="form-check-label" for="modePriceStock">Preços — Apenas estoque</label>
                    </div>
                    <div class="form-check mt-1">
                        <input class="form-check-input" type="radio" name="listMode" id="modeStock"
                               checked="@(_mode == ProductListMode.Stock)" @onchange="() => SetMode(ProductListMode.Stock)" />
                        <label class="form-check-label" for="modeStock">Estoque</label>
                    </div>
                </fieldset>
            </div>
            <div class="col-md-5">
                <label class="form-label">Grupo de Produtos</label>
                <select class="form-select form-select-sm" multiple size="10" @onchange="OnGroupsChanged" disabled="@_allGroups">
                    @foreach (var g in _groups)
                    {
                        <option value="@g.Id" selected="@_selectedGroupIds.Contains((byte)g.Id)">@g.Name</option>
                    }
                </select>
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="allGroups" @bind="_allGroups" />
                    <label class="form-check-label" for="allGroups">Tudo</label>
                </div>
            </div>
            <div class="col-md-3 d-flex flex-column gap-2 justify-content-end">
                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="Visualizar">Listar</button>
                <a class="btn btn-primary btn-sm" href="@GetExportPdfUrl()" target="_blank" rel="noopener">Exportar PDF</a>
                <a class="btn btn-success btn-sm" href="@GetExportExcelUrl()" target="_blank" rel="noopener">Exportar Excel</a>
            </div>
        </div>
    </div>
</div>

@code {
    private ProductListMode _mode = ProductListMode.PriceAll;
    private bool _allGroups;
    private readonly HashSet<byte> _selectedGroupIds = new();
    private IReadOnlyList<IdNameDto> _groups = new List<IdNameDto>();
    private string? _error;

    [Inject] private IProductReferenceService ReferenceService { get; set; } = null!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        _groups = await ReferenceService.GetProductGroupsByClassAsync(1);
    }

    private void SetMode(ProductListMode mode) => _mode = mode;

    private void OnGroupsChanged(ChangeEventArgs e)
    {
        _selectedGroupIds.Clear();
        if (e.Value is string[] values)
        {
            foreach (var v in values)
            {
                if (byte.TryParse(v, out var id))
                    _selectedGroupIds.Add(id);
            }
        }
    }

    private ProductListRequest BuildRequest()
    {
        return new ProductListRequest
        {
            Mode = _mode,
            AllGroups = _allGroups,
            GroupIds = _selectedGroupIds.OrderBy(x => x).ToList()
        };
    }

    private bool ValidateSelection()
    {
        if (_allGroups || _selectedGroupIds.Count > 0)
        {
            _error = null;
            return true;
        }
        _error = "Selecione ao menos um grupo de produtos ou marque \"Tudo\".";
        return false;
    }

    private string BuildQueryString()
    {
        var req = BuildRequest();
        var mode = req.Mode switch
        {
            ProductListMode.PriceInStock => "priceInStock",
            ProductListMode.Stock => "stock",
            _ => "priceAll"
        };
        var qs = $"mode={Uri.EscapeDataString(mode)}&allGroups={(req.AllGroups ? "1" : "0")}";
        if (!req.AllGroups && req.GroupIds.Count > 0)
            qs += "&groupIds=" + Uri.EscapeDataString(string.Join(",", req.GroupIds));
        return qs;
    }

    private string GetExportPdfUrl() => $"/api/productlist/export/pdf?{BuildQueryString()}";
    private string GetExportExcelUrl() => $"/api/productlist/export/excel?{BuildQueryString()}";

    private async Task Visualizar()
    {
        if (!ValidateSelection())
            return;
        await JSRuntime.InvokeVoidAsync("open", $"/lista/geral/imprimir?{BuildQueryString()}", "_blank", "height=600,width=1000,left=5,top=5,scrollbars=1,resizable=1");
    }
}
