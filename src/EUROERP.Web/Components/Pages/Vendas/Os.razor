@page "/vendas/os/{OrderId:int}"
@using EUROERP.Application.Clients
@using EUROERP.Application.Orders
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<PageTitle>Ordem de Serviço #@OrderId</PageTitle>

@if (_header == null && !_loadingHeader)
{
    <div class="alert alert-warning">OS não encontrada.</div>
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }
    return;
}

@if (_loadingHeader)
{
    <div class="text-muted">Carregando OS...</div>
    return;
}

<div class="card mb-2 order-header-compact">
    <div class="card-body py-2 px-3">
        <div class="d-flex flex-wrap align-items-center gap-2 gap-md-3 mb-1 small">
            <span class="order-header-order-id">#@_header!.OrderId</span>
            <span class="badge @GetOrderStatusBadgeClass(_header.Status)">@GetOrderStatusName(_header.Status)</span>
            <span class="badge @GetOrderModeBadgeClass(_header.Mode)">@(!string.IsNullOrWhiteSpace(_header.ModeDescription) ? _header.ModeDescription : (_header.Mode == "Q" ? "Orçamento" : "Venda"))</span>
            <span class="text-muted">Produtos</span>
            <span class="order-header-date">@_header.OrderDate.ToString("dd/MM/yyyy")</span>
            @if (_header.Status == "E" && _header.SentDate.HasValue)
            {
                <span class="text-muted">Enviado em <strong class="text-body">@_header.SentDate.Value.ToString("dd/MM/yyyy HH:mm")</strong></span>
            }
            <span class="vr d-none d-md-inline"></span>
            <span class="text-muted">Vend.: @_header.SalesAgent</span>
        </div>
        <div class="order-header-client-name mb-1">
            @_header.SocialName <span class="text-muted fw-normal small">(#@_header.ClientId — @_header.ClientName)</span>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2 gap-md-3 mb-1 small text-muted">
            <span>@_header.AddressStreet @_header.AddressNumber @(string.IsNullOrEmpty(_header.AddressBlock) ? "" : _header.AddressBlock) @(string.IsNullOrEmpty(_header.AddressComplement) ? "" : _header.AddressComplement)</span>
            <span>CEP @_header.AddressZipCode</span>
            <span>@_header.City / @_header.State</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(_header.Phone1) || !string.IsNullOrWhiteSpace(_header.Phone2) || !string.IsNullOrWhiteSpace(_header.Phone3) || !string.IsNullOrWhiteSpace(_header.Celular))
        {
            <div class="small text-muted mb-1">
                <strong>Telefones:</strong> @_header.Phone1 / @_header.Phone2 / @_header.Phone3 / @_header.Celular
            </div>
        }
        <div class="d-flex flex-wrap align-items-center gap-3 pt-1 border-top border-secondary border-opacity-25 small">
            <span><span class="text-muted">Limite</span> <strong class="text-body">R$ @_header.LimitAmount.ToString("N2")</strong></span>
            <span><span class="text-muted">Devido</span> <strong class="text-body">R$ @_header.DueAmount.ToString("N2")</strong></span>
            <span><span class="text-muted">Saldo</span> <strong class="@(_header.BalanceForPurchase >= 0 ? "text-success" : "text-danger")">R$ @_header.BalanceForPurchase.ToString("N2")</strong></span>
        </div>
    </div>
</div>

@if (_header != null && (_canEdit || HasOrderCar(_header) || !string.IsNullOrWhiteSpace(_header.CarProblem)))
{
    <div class="card mb-2">
        <div class="card-body py-2 px-3 small">
            <div class="row g-2 align-items-start">
                <div class="col-auto pt-1">
                    @if (_canEdit)
                    {
                        <button type="button" class="btn btn-link p-0 border-0 os-truck-btn" title="Selecionar veículo da frota" @onclick="AbrirModalFrota" disabled="@_carBusy">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                <path d="M0 3.5A1.5 1.5 0 0 1 1.5 2h9A1.5 1.5 0 0 1 12 3.5V5h1.02a1.5 1.5 0 0 1 1.17.563l1.481 1.85a1.5 1.5 0 0 1 .329.938V10.5a1.5 1.5 0 0 1-1.5 1.5H14a2 2 0 1 1-4 0H5a2 2 0 1 1-3.998-.085A1.5 1.5 0 0 1 0 10.5v-7zm1.294 7.456A1.999 1.999 0 0 1 4.002 13h5.996a2 1.999 0 0 1 .998-1.75v-.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5v.5a1.999 1.999 0 0 1 .346 1.456zM12 5.5a.5.5 0 0 1 .5.5v.293l-1.378 1.378A.5.5 0 0 1 11 7.207V5.5a.5.5 0 0 1 .5-.5z"/>
                            </svg>
                        </button>
                    }
                </div>
                @if (HasOrderCar(_header))
                {
                    <div class="col-md-3">
                        <div class="text-muted mb-0">Descrição</div>
                        <strong>@_header.CarDescription</strong>
                    </div>
                    <div class="col-md-2">
                        <div class="text-muted mb-0">Placa</div>
                        <strong>@_header.CarPlate</strong>
                    </div>
                    <div class="col-md-2">
                        <div class="text-muted mb-0">KM atual</div>
                        @if (_canEdit)
                        {
                            <input type="number" class="form-control form-control-sm" step="0.01" min="0" @bind="_carKm" />
                        }
                        else
                        {
                            <strong>@(_carKm?.ToString("N0") ?? "—")</strong>
                        }
                    </div>
                    @if (_canEdit)
                    {
                        <div class="col-auto pt-4">
                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="RemoverVeiculo" disabled="@_carBusy" title="Remover veículo">×</button>
                        </div>
                    }
                }
                else if (_canEdit)
                {
                    <div class="col pt-2 text-muted">Clique no caminhão para vincular um veículo da frota do cliente.</div>
                }
                <div class="@(HasOrderCar(_header) ? "col-md" : "col")">
                    <label class="form-label mb-0">Dados adicionais / problema</label>
                    @if (_canEdit)
                    {
                        <textarea class="form-control form-control-sm" rows="2" @bind="_carProblem"></textarea>
                    }
                    else if (!string.IsNullOrWhiteSpace(_carProblem))
                    {
                        <div>@_carProblem</div>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_carMessage))
            {
                <div class="alert alert-danger py-1 small mt-2 mb-0">@_carMessage</div>
            }
        </div>
    </div>
}

@if (_canEdit)
{
    <div class="card mb-3 pedido-insert-product-card">
        <div class="card-header"><h6 class="mb-0">Inserir novo produto</h6></div>
        <div class="card-body">
            <div class="row align-items-end">
                <div class="col-md-5">
                    <label class="form-label">Produto (nome)</label>
                    <div class="position-relative @(_showProductSuggestions && _productSuggestions.Count > 0 ? "pedido-suggestions-open" : null)">
                        <input type="text"
                               id="pedido-product-input"
                               class="form-control form-control-sm"
                               placeholder="Digite pelo menos 2 caracteres... (F2 busca)"
                               @bind="_productSearch"
                               @bind:event="oninput"
                               @bind:after="OnProductSearchChanged"
                               @onblur="OnProductSearchBlur"
                               @onkeydown="OnProductKeydown"
                               autocomplete="off" />
                        @if (_loadingProductSuggestions)
                        {
                            <span class="position-absolute top-50 end-0 translate-middle-y pe-2 small text-muted">...</span>
                        }
                        @if (_showProductSuggestions)
                        {
                            <div id="pedido-product-suggestions-list" class="position-absolute start-0 end-0 top-100 mt-1 border rounded bg-white shadow-sm" style="z-index: 9999;" @onmousedown="OnProductDropdownMouseDown" @onmousedown:preventDefault>
                                @if (_productSuggestions.Count == 0)
                                {
                                    <div class="p-2 small text-muted">Nenhum produto encontrado.</div>
                                }
                                else
                                {
                                    @for (var i = 0; i < _productSuggestions.Count; i++)
                                    {
                                        var p = _productSuggestions[i];
                                        var isHighlighted = i == _productSuggestionHighlightIndex;
                                        <div class="px-2 py-1 small cursor-pointer @(isHighlighted ? "pedido-autocomplete-highlight" : "")" @onmousedown="() => SelectProductSuggestion(p)" style="cursor: pointer;">
                                            @p.Name — Estoque: @p.Stock — R$ @p.Price.ToString("N2")
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
                @if (_selectedProductForSale != null)
                {
                    <div class="col-md-3">
                        <label class="form-label">Preço unit.</label>
                        <p class="form-control-plaintext small mb-0">@_selectedProductForSale.CurrencySymbol @(_selectedProductForSale.CostInd ? _selectedProductForSale.CostFinal.ToString("N2") : _selectedProductForSale.Price.ToString("N2")) — Desc. @_selectedProductForSale.Discount.ToString("N1")%</p>
                    </div>
                }
                <div class="col-md-2">
                    <label class="form-label">Quantidade</label>
                    <input type="number" id="pedido-quantity-input" class="form-control form-control-sm" step="0.001" min="0.001" @bind="_quantity" @bind:event="oninput" @onkeydown="OnQuantityKeydown" />
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-primary btn-sm w-100 pedido-add-to-cart-btn" @onclick="AdicionarProduto" disabled="@(_selectedProductId == 0 || _quantity <= 0 || _addingProduct)" title="Adicionar Produto" aria-label="Adicionar Produto">
                        @if (_addingProduct)
                        {
                            <span class="small">...</span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>
                        }
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_productMessage))
            {
                <div class="alert alert-danger py-2 small mt-2 mb-0">@_productMessage</div>
            }
        </div>
    </div>
}

@* Modal Busca rica (F2) *@
@if (_showBuscaRicaModal)
{
    <div class="modal-backdrop-pedido" style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1050;" @onclick="FecharBuscaRica">
        <div class="modal-dialog-pedido" style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #fff; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.2); max-width: 600px; width: 90%; max-height: 80vh; display: flex; flex-direction: column; z-index: 1051;" @onclick:stopPropagation="true" @onkeydown="OnBuscaRicaKeydown" tabindex="-1">
            <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
                <h6 class="mb-0">Busca de produto (F2) — ESC para fechar</h6>
                <button type="button" class="btn btn-link btn-sm p-0 text-secondary" @onclick="FecharBuscaRica" aria-label="Fechar">×</button>
            </div>
            <div class="p-3 border-bottom">
                <input type="text"
                       id="pedido-busca-rica-input"
                       @ref="_buscaRicaInputRef"
                       class="form-control form-control-sm"
                       placeholder="Digite pelo menos 2 caracteres..."
                       @bind="_buscaRicaSearch"
                       @bind:event="oninput"
                       @bind:after="OnBuscaRicaSearchChanged"
                       @onkeydown="OnBuscaRicaKeydown"
                       autocomplete="off" />
            </div>
            <div class="p-0 flex-grow-1 overflow-auto" style="min-height: 200px;">
                @if (_loadingBuscaRica)
                {
                    <div class="p-3 text-muted small">Buscando...</div>
                }
                else if ((_buscaRicaSearch?.Trim().Length ?? 0) < 2)
                {
                    <div class="p-3 text-muted small">Digite pelo menos 2 caracteres para buscar.</div>
                }
                else if (_buscaRicaSuggestions.Count == 0)
                {
                    <div class="p-3 text-muted small">Nenhum produto encontrado.</div>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Cód.</th>
                                <th>Nome</th>
                                <th>Estoque</th>
                                <th>Preço</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in _buscaRicaSuggestions)
                            {
                                <tr role="button" @onclick="() => SelecionarProdutoBuscaRica(p)">
                                    <td>@p.ProductId</td>
                                    <td>@p.Name</td>
                                    <td>@p.Stock</td>
                                    <td>R$ @p.Price.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="p-3 border-top small text-muted">Clique em um produto para selecionar.</div>
        </div>
    </div>
}

@* Modal seleção de veículo (frota) *@
@if (_showCarModal)
{
    <div class="modal-backdrop-pedido" style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1050;" @onclick="FecharModalFrota">
        <div class="modal-dialog-pedido" style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #fff; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.2); max-width: 560px; width: 90%; max-height: 80vh; display: flex; flex-direction: column; z-index: 1051;" @onclick:stopPropagation="true">
            <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
                <h6 class="mb-0">Frota — @_header?.SocialName</h6>
                <button type="button" class="btn btn-link btn-sm p-0 text-secondary" @onclick="FecharModalFrota" aria-label="Fechar">×</button>
            </div>
            <div class="p-0 flex-grow-1 overflow-auto" style="min-height: 160px;">
                @if (_loadingCars)
                {
                    <div class="p-3 text-muted small">Carregando frota...</div>
                }
                else if (_clientCars.Count == 0)
                {
                    <div class="p-3 text-muted small">Nenhum veículo cadastrado para este cliente. Cadastre em Clientes → Frota.</div>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Descrição</th>
                                <th>Placa</th>
                                <th class="text-end">Últ. KM</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var car in _clientCars)
                            {
                                var isSelected = _header?.CarId == car.Id;
                                <tr class="@(isSelected ? "table-primary" : null)">
                                    <td>@car.Description</td>
                                    <td>@car.Plate</td>
                                    <td class="text-end">@car.LastKm.ToString("N0")</td>
                                    <td class="text-end">
                                        @if (isSelected)
                                        {
                                            <span class="badge bg-primary">Atual</span>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => SelecionarVeiculo(car.Id)" disabled="@_carBusy">Selecionar</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="p-3 border-top">
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="FecharModalFrota">Fechar</button>
            </div>
        </div>
    </div>
}

@* Modal desconto individual por produto (legacy discountProduct.aspx) *@
@if (_showItemDiscountModal && _discountItem != null)
{
    <div class="modal-backdrop-pedido" style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1050;" @onclick="FecharModalDescontoItem">
        <div class="modal-dialog-pedido" style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #fff; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.2); max-width: 420px; width: 90%; z-index: 1051;" @onclick:stopPropagation="true">
            <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
                <h6 class="mb-0">Desconto individual</h6>
                <button type="button" class="btn btn-link btn-sm p-0 text-secondary" @onclick="FecharModalDescontoItem" aria-label="Fechar">×</button>
            </div>
            <div class="p-3">
                <p class="small mb-1">Produto: <strong>@_discountItem.Name</strong></p>
                <p class="small mb-3">Preço atual: <strong>R$ @_discountItem.Price.ToString("N2")</strong></p>
                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label small" for="item-discount-pct">Desconto</label>
                        <div class="input-group input-group-sm">
                            <input id="item-discount-pct" type="number" class="form-control form-control-sm" step="0.01" min="0" max="100" @bind="_itemDiscountPercent" />
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label small" for="item-new-price">Novo preço</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">R$</span>
                            <input id="item-new-price" type="number" class="form-control form-control-sm" step="0.01" min="0" @bind="_itemNewListPrice" placeholder="opcional" />
                        </div>
                    </div>
                </div>
                <p class="small text-muted mt-2 mb-0">
                    Preço com desconto: R$ @CalcularPrecoComDesconto(_itemNewListPrice ?? _discountItem.Price, _itemDiscountPercent).ToString("N2")
                </p>
                @if (!string.IsNullOrEmpty(_itemDiscountMessage))
                {
                    <div class="alert alert-danger py-2 small mt-2 mb-0">@_itemDiscountMessage</div>
                }
            </div>
            <div class="p-3 border-top d-flex gap-2">
                <button type="button" class="btn btn-sm btn-primary" @onclick="GravarDescontoItemAsync" disabled="@_itemDiscountBusy">@(_itemDiscountBusy ? "Gravando..." : "Gravar")</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="FecharModalDescontoItem">Fechar</button>
            </div>
        </div>
    </div>
}

<div class="card grid-card mb-3 pedido-cart-card">
    <div class="card-header py-2 d-flex align-items-center justify-content-between">
        <h6 class="mb-0">Carrinho</h6>
        @if (_details.Count > 0)
        {
            <span class="badge rounded-pill pedido-cart-count">@_details.Count @(_details.Count == 1 ? "item" : "itens")</span>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-bordered mb-0 data-grid-table pedido-cart-table">
                <thead class="table-light">
                    <tr>
                        <th>Código</th>
                        <th>Nome</th>
                        <th>Qtd</th>
                        <th>Preço unit.</th>
                        <th>Desc. %</th>
                        <th>Total</th>
                        @if (_canEdit)
                        {
                            <th class="pedido-cart-actions">Ações</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (_details.Count == 0)
                    {
                        <tr><td colspan="@(_canEdit ? 7 : 6)" class="text-muted text-center py-2 small">Nenhum item no carrinho.</td></tr>
                    }
                    else
                    {
                        @foreach (var d in _details)
                        {
                            <tr class="pedido-cart-row">
                                <td class="pedido-cart-code">@d.LionCode</td>
                                <td class="pedido-cart-name">@d.Name</td>
                                <td class="pedido-cart-qty text-end">@d.Quantity</td>
                                <td class="pedido-cart-price text-end">@d.Price.ToString("N2")</td>
                                <td class="pedido-cart-disc text-end">@d.Discount.ToString("N1")</td>
                                <td class="pedido-cart-total text-end">@d.TotalPrice.ToString("N2")</td>
                                @if (_canEdit)
                                {
                                    <td class="pedido-cart-actions">
                                        <button type="button" class="pedido-icon-btn pedido-icon-btn-remove" @onclick="() => RemoverItem(d)" title="Remover" aria-label="Remover">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/><path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/></svg>
                                        </button>
                                        <button type="button" class="pedido-icon-btn pedido-icon-btn-edit" @onclick="() => EditarItem(d)" title="Editar" aria-label="Editar">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/></svg>
                                        </button>
                                        <button type="button" class="pedido-icon-btn pedido-icon-btn-discount" @onclick="() => AbrirModalDescontoItem(d)" title="Desconto individual" aria-label="Desconto individual">
                                            <span class="pedido-icon-percent" aria-hidden="true">%</span>
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
                @if (_details.Count > 0 && _header != null)
                {
                    <tfoot class="table-light pedido-cart-tfoot">
                        <tr>
                            <td colspan="5" class="text-end pt-1">Subtotal (itens)</td>
                            <td class="pt-1">@_details.Sum(d => d.TotalPrice).ToString("N2")</td>
                            @if (_canEdit) { <td class="pedido-cart-actions pt-1"></td> }
                        </tr>
                        @if ((_header.Credit ?? 0) != 0)
                        {
                            <tr class="pedido-cart-tfoot-detail">
                                <td colspan="5" class="text-end pt-1">(-) Crédito</td>
                                <td class="pt-1">@((_header.Credit ?? 0).ToString("N2"))</td>
                                @if (_canEdit) { <td class="pedido-cart-actions pt-1"></td> }
                            </tr>
                        }
                        @if ((_header.Discount ?? 0) != 0)
                        {
                            <tr class="pedido-cart-tfoot-detail">
                                <td colspan="5" class="text-end pt-1">(-) Desconto (@((_header.Discount ?? 0).ToString("N1"))%)</td>
                                <td class="pt-1">@(((_details.Sum(d => d.TotalPrice) - (_header.Credit ?? 0)) * ((_header.Discount ?? 0) / 100m)).ToString("N2"))</td>
                                @if (_canEdit) { <td class="pedido-cart-actions pt-1"></td> }
                            </tr>
                        }
                        @if ((_header.OtherExpenses ?? 0) != 0)
                        {
                            <tr class="pedido-cart-tfoot-detail">
                                <td colspan="5" class="text-end pt-1">(+) Outras despesas</td>
                                <td class="pt-1">@((_header.OtherExpenses ?? 0).ToString("N2"))</td>
                                @if (_canEdit) { <td class="pedido-cart-actions pt-1"></td> }
                            </tr>
                        }
                        @if ((_header.ShipmentCost ?? 0) != 0 && _header.ChargeShipment)
                        {
                            <tr class="pedido-cart-tfoot-detail">
                                <td colspan="5" class="text-end pt-1">(+) Frete</td>
                                <td class="pt-1">@((_header.ShipmentCost ?? 0).ToString("N2"))</td>
                                @if (_canEdit) { <td class="pedido-cart-actions pt-1"></td> }
                            </tr>
                        }
                        <tr>
                            <td colspan="5" class="text-end pt-1"><strong>Total</strong></td>
                            <td class="pt-1"><strong>@_header.OrderTotalAmount.ToString("N2")</strong></td>
                            @if (_canEdit) { <td class="pedido-cart-actions pt-1"></td> }
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>

@if (_canEdit)
{
    <div class="card mb-3 pedido-credit-discount-card">
        <div class="card-header"><h6 class="mb-0">Crédito, Desconto e Despesas</h6></div>
        <div class="card-body">
            <div class="row g-2 align-items-end">
