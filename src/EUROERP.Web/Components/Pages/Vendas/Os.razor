    private static string GetOrderModeBadgeClass(string mode) => mode == "Q" ? "bg-secondary" : "bg-success";

    private static string GetOrderStatusBadgeClass(string status) => status switch
    {
        "I" => "bg-warning text-dark",
        "R" => "bg-info text-dark",
        "F" => "bg-secondary",
        "C" => "bg-danger",
        "E" => "bg-primary",
        _ => "bg-secondary"
    };

    private static string GetOrderStatusName(string status) => status switch
    {
        "I" => "Incompleto",
        "R" => "Reaberto",
        "F" => "Fechado",
        "C" => "Cancelado",
        "E" => "Enviado",
        _ => "Indefinido"
    };
}
