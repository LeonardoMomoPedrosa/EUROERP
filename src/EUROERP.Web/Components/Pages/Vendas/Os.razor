@code {
    [Parameter]
    public int OrderId { get; set; }

    [SupplyParameterFromQuery(Name = "from")]
    public string? From { get; set; }

    private OrderHeaderDto? _header;
    private List<OrderDetailItemDto> _details = new();
    private bool _loadingHeader = true;
    private int _loadedOrderId;
    private bool _canEdit;
    private bool _showClosedOrderActions;
    private bool _showPerformSale;

    private bool _printModalOpen;
    private bool _printModalLoading;
    private OrderForPrintDto? _printModalData;

    private string _productSearch = "";
    private int _selectedProductId;
    private ProductForSaleDto? _selectedProductForSale;
    private List<ProductForSaleSuggestionDto> _productSuggestions = new();
    private bool _showProductSuggestions;
    private int _productSuggestionHighlightIndex = -1;
    private bool _loadingProductSuggestions;
    private bool _selectingProductSuggestions;
    private CancellationTokenSource? _productDebounceCts;
    private decimal _quantity = 1;
    private bool _addingProduct;
    private string? _productMessage;

    private bool _showBuscaRicaModal;
    private bool _buscaRicaFocusPending;
    private ElementReference _buscaRicaInputRef;
    private string _buscaRicaSearch = "";
    private List<ProductForSaleSuggestionDto> _buscaRicaSuggestions = new();
    private bool _loadingBuscaRica;
    private CancellationTokenSource? _buscaRicaDebounceCts;

    private decimal? _credit;
    private decimal? _discount;
    private decimal? _otherExpenses;
    private decimal? _shipmentCost;
    private bool _chargeShipment = true;
    private decimal? _carKm;
    private string? _carProblem;
    private string? _carMessage;
    private bool _carBusy;
    private bool _showCarModal;
    private bool _loadingCars;
    private IReadOnlyList<ClientCarDto> _clientCars = Array.Empty<ClientCarDto>();
    private bool _showItemDiscountModal;
    private OrderDetailItemDto? _discountItem;
    private decimal _itemDiscountPercent;
    private decimal? _itemNewListPrice;
    private string? _itemDiscountMessage;
    private bool _itemDiscountBusy;
    private string? _extraMessage;
    private bool _busy;
    private bool _aplicando;
    private string? _errorMessage;

    private string? _currentUserId;
    private string? _applicationId;
    private bool _productInputFocusedOnce;

    [Inject] private IOrderService OrderService { get; set; } = null!;
    [Inject] private IClientService ClientService { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] private IConfiguration Configuration { get; set; } = null!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = state.User.Identity?.Name ?? "SYS";
        _applicationId = Configuration["Authentication:ApplicationName"] ?? "LionSystem";
    }

    protected override async Task OnParametersSetAsync()
    {
        if (OrderId <= 0)
        {
            _header = null;
            _loadingHeader = false;
            _errorMessage = "Número da OS inválido.";
            return;
        }
        if (_loadedOrderId == OrderId && _header != null)
            return;
        _loadedOrderId = OrderId;
        await CarregarPedidoAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loadingHeader && _canEdit && !_productInputFocusedOnce)
        {
            _productInputFocusedOnce = true;
            await Task.Delay(50);
            await FocusProductInputAsync();
        }

        if (_buscaRicaFocusPending && _showBuscaRicaModal)
        {
            _buscaRicaFocusPending = false;
            try
            {
                await Task.Delay(50);
                await _buscaRicaInputRef.FocusAsync();
            }
            catch { /* ignore */ }
        }
    }

    private async Task CarregarPedidoAsync()
    {
        _loadingHeader = true;
        _errorMessage = null;
        try
        {
            _header = await OrderService.GetOrderHeaderAsync(OrderId);
            if (_header == null)
                return;
            _canEdit = _header.Status == "I" || _header.Status == "R";
            _showClosedOrderActions = _header.Status == "F" || _header.Status == "E";
            _showPerformSale = _header.Status == "F" && _header.Mode == "Q";
            _credit = _header.Credit;
            _discount = _header.Discount;
            _otherExpenses = _header.OtherExpenses;
            _shipmentCost = _header.ShipmentCost;
            _chargeShipment = _header.ChargeShipment;
            _carKm = _header.CarKm;
            _carProblem = _header.CarProblem;
            await CarregarDetalhesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao carregar pedido: " + ex.Message;
        }
        finally
        {
            _loadingHeader = false;
        }
    }

    private async Task CarregarDetalhesAsync()
    {
        try
        {
            _details = (await OrderService.GetOrderDetailsAsync(OrderId)).ToList();
            if (_header != null)
            {
                _header = await OrderService.GetOrderHeaderAsync(OrderId);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao carregar itens: " + ex.Message;
        }
    }

    private static bool HasOrderCar(OrderHeaderDto header) =>
        header.CarId.HasValue && header.CarId.Value > 0;

    private async Task RefreshCarHeaderAsync()
    {
        _header = await OrderService.GetOrderHeaderAsync(OrderId);
        if (_header == null)
            return;
        _carKm = _header.CarKm;
        _carProblem = _header.CarProblem;
    }

    private async Task AbrirModalFrota()
    {
        if (_header == null || !_canEdit)
            return;
        _carMessage = null;
        _showCarModal = true;
        _loadingCars = true;
        StateHasChanged();
        try
        {
            _clientCars = await ClientService.GetCarsByClientAsync(_header.ClientId);
        }
        catch (Exception ex)
        {
            _carMessage = ex.Message;
            _clientCars = Array.Empty<ClientCarDto>();
        }
        finally
        {
            _loadingCars = false;
            StateHasChanged();
        }
    }

    private void FecharModalFrota()
    {
        _showCarModal = false;
        _clientCars = Array.Empty<ClientCarDto>();
    }

    private async Task SelecionarVeiculo(int carId)
    {
        _carMessage = null;
        _carBusy = true;
        try
        {
            await OrderService.AssignOrderCarAsync(OrderId, carId);
            await RefreshCarHeaderAsync();
            FecharModalFrota();
        }
        catch (Exception ex)
        {
            _carMessage = ex.Message;
        }
        finally
        {
            _carBusy = false;
        }
    }

    private async Task RemoverVeiculo()
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Remover o veículo desta OS?"))
            return;
        _carMessage = null;
        _carBusy = true;
        try
        {
            await OrderService.RemoveOrderCarAsync(OrderId);
            await RefreshCarHeaderAsync();
        }
        catch (Exception ex)
        {
            _carMessage = ex.Message;
        }
        finally
        {
            _carBusy = false;
        }
    }

    private async Task OnProductSearchChanged()
    {
        _showProductSuggestions = (_productSearch?.Trim().Length ?? 0) >= 2;
        _productDebounceCts?.Cancel();
        _productDebounceCts = new CancellationTokenSource();
        var ct = _productDebounceCts.Token;
        if ((_productSearch?.Trim().Length ?? 0) < 2)
        {
            _productSuggestions = new List<ProductForSaleSuggestionDto>();
            _productSuggestionHighlightIndex = -1;
            _selectedProductId = 0;
            _selectedProductForSale = null;
            StateHasChanged();
            return;
        }
        try { await Task.Delay(300, ct); } catch (TaskCanceledException) { return; }
        _loadingProductSuggestions = true;
        StateHasChanged();
        try
        {
            var list = await OrderService.GetProductSuggestionsForSaleAsync(_productSearch!.Trim(), OrderId, 20, ct);
            if (!ct.IsCancellationRequested) { _productSuggestions = list.ToList(); _showProductSuggestions = true; _productSuggestionHighlightIndex = _productSuggestions.Count > 0 ? 0 : -1; }
        }
        catch (OperationCanceledException) { }
        finally
        {
            if (!ct.IsCancellationRequested) { _loadingProductSuggestions = false; StateHasChanged(); }
        }
    }

    private async Task OnProductSearchBlur()
    {
        await Task.Delay(150);
        if (!_selectingProductSuggestions)
        {
            _showProductSuggestions = false;
            _productSuggestionHighlightIndex = -1;
        }
        _selectingProductSuggestions = false;
        StateHasChanged();
    }

    private void OnProductDropdownMouseDown(MouseEventArgs _) => _selectingProductSuggestions = true;

    private async Task SelectProductSuggestion(ProductForSaleSuggestionDto p)
    {
        _selectingProductSuggestions = true;
        _showProductSuggestions = false;
        _productSearch = p.Name;
        _selectedProductId = p.ProductId;
        _productMessage = null;
        if (_header != null)
        {
            _selectedProductForSale = await OrderService.GetProductForSaleAsync(p.ProductId, OrderId, _header.ClientId);
        }
        StateHasChanged();
    }

    private async Task OnProductKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            if (_showBuscaRicaModal)
            {
                FecharBuscaRica();
                return;
            }
            LimparSelecaoProduto();
            _productSuggestionHighlightIndex = -1;
            StateHasChanged();
            return;
        }
        if (e.Key == "F2")
        {
            _showBuscaRicaModal = true;
            _buscaRicaSearch = _productSearch ?? "";
            _buscaRicaFocusPending = true;
            if (_buscaRicaSearch.Trim().Length >= 2)
                await BuscarBuscaRicaAsync();
            StateHasChanged();
            return;
        }
        if (_showProductSuggestions && _productSuggestions.Count > 0)
        {
            if (e.Key == "ArrowDown" || e.Key == "Down")
            {
                _productSuggestionHighlightIndex = Math.Min(_productSuggestionHighlightIndex + 1, _productSuggestions.Count - 1);
                StateHasChanged();
                return;
            }
            if (e.Key == "ArrowUp" || e.Key == "Up")
            {
                _productSuggestionHighlightIndex = Math.Max(_productSuggestionHighlightIndex - 1, 0);
                StateHasChanged();
                return;
            }
            if (e.Key == "Enter" && _productSuggestionHighlightIndex >= 0 && _productSuggestionHighlightIndex < _productSuggestions.Count)
            {
                var p = _productSuggestions[_productSuggestionHighlightIndex];
                await SelectProductSuggestion(p);
                _showProductSuggestions = false;
                _productSuggestionHighlightIndex = -1;
                await FocusQuantityAsync();
                return;
            }
        }
        if (e.Key == "Enter" && _selectedProductId != 0)
        {
            _showProductSuggestions = false;
            _productSuggestionHighlightIndex = -1;
            await FocusQuantityAsync();
        }
    }

    private async Task OnBuscaRicaSearchChanged()
    {
        _buscaRicaDebounceCts?.Cancel();
        _buscaRicaDebounceCts = new CancellationTokenSource();
        var ct = _buscaRicaDebounceCts.Token;
        if ((_buscaRicaSearch?.Trim().Length ?? 0) < 2)
        {
            _buscaRicaSuggestions = new List<ProductForSaleSuggestionDto>();
            StateHasChanged();
            return;
        }
        try { await Task.Delay(300, ct); } catch (TaskCanceledException) { return; }
        await BuscarBuscaRicaAsync();
    }

    private async Task BuscarBuscaRicaAsync()
    {
        if ((_buscaRicaSearch?.Trim().Length ?? 0) < 2) return;
        _loadingBuscaRica = true;
        StateHasChanged();
        try
        {
            var list = await OrderService.GetProductSuggestionsForSaleAsync(_buscaRicaSearch!.Trim(), OrderId, 30);
            _buscaRicaSuggestions = list.ToList();
        }
        catch (Exception)
        {
            _buscaRicaSuggestions = new List<ProductForSaleSuggestionDto>();
        }
        finally
        {
            _loadingBuscaRica = false;
            StateHasChanged();
        }
    }

    private void FecharBuscaRica()
    {
        _showBuscaRicaModal = false;
        _buscaRicaSearch = "";
        _buscaRicaSuggestions = new List<ProductForSaleSuggestionDto>();
    }

    private void OnBuscaRicaKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            FecharBuscaRica();
    }

    private async Task SelecionarProdutoBuscaRica(ProductForSaleSuggestionDto p)
    {
        await SelectProductSuggestion(p);
        FecharBuscaRica();
    }

    private async Task OnQuantityKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            LimparSelecaoProduto();
            await FocusProductInputAsync();
            return;
        }
        if (e.Key == "Enter")
        {
            await AdicionarProduto();
            await FocusProductInputAsync();
        }
    }

    private async Task FocusQuantityAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('#pedido-quantity-input')?.focus()");
        }
        catch { /* ignore */ }
    }

    private async Task FocusProductInputAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('pedido-product-input')?.focus()");
        }
        catch { /* ignore */ }
    }

    private void LimparSelecaoProduto()
    {
        _showProductSuggestions = false;
        _selectedProductId = 0;
        _selectedProductForSale = null;
        _productSearch = "";
        _productMessage = null;
        _quantity = 1;
        StateHasChanged();
    }

    private async Task AdicionarProduto()
    {
        if (_header == null || _selectedProductId == 0) return;
        _productMessage = null;
        if (_quantity <= 0) { _productMessage = "Informe quantidade maior que zero."; return; }
        _addingProduct = true;
        try
        {
            await OrderService.AddOrderDetailAsync(OrderId, _selectedProductId, _quantity, _header.ClientId, _applicationId!, _currentUserId!);
            _quantity = 1;
            _selectedProductId = 0;
            _selectedProductForSale = null;
            _productSearch = "";
            await CarregarDetalhesAsync();
            await FocusProductInputAsync();
        }
        catch (Exception ex)
        {
            _productMessage = ex.Message;
        }
        finally
        {
            _addingProduct = false;
        }
    }

    private async Task RemoverItem(OrderDetailItemDto d)
    {
        if (_header == null) return;
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Remover este item do carrinho?")) return;
        _busy = true;
        try
        {
            await OrderService.RemoveOrderDetailAsync(OrderId, d.ProductId, _header.ClientId);
            await CarregarDetalhesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task EditarItem(OrderDetailItemDto d)
    {
        if (_header == null) return;
        _busy = true;
        try
        {
            await OrderService.RemoveOrderDetailAsync(OrderId, d.ProductId, _header.ClientId);
            _selectedProductId = d.ProductId;
            _productSearch = d.Name;
            _quantity = d.Quantity;
            _selectedProductForSale = await OrderService.GetProductForSaleAsync(d.ProductId, OrderId, _header.ClientId);
            await CarregarDetalhesAsync();
            await FocusQuantityAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void AbrirModalDescontoItem(OrderDetailItemDto d)
    {
        _discountItem = d;
        _itemDiscountPercent = d.Discount;
        _itemNewListPrice = null;
        _itemDiscountMessage = null;
        _showItemDiscountModal = true;
    }

    private void FecharModalDescontoItem()
    {
        _showItemDiscountModal = false;
        _discountItem = null;
        _itemDiscountMessage = null;
    }

    private static decimal CalcularPrecoComDesconto(decimal listPrice, decimal discountPercent) =>
        decimal.Round(decimal.Round(listPrice, 2) * (1 - discountPercent / 100m), 2);

    private async Task GravarDescontoItemAsync()
    {
        if (_discountItem == null) return;
        _itemDiscountMessage = null;
        if (_itemDiscountPercent < 0 || _itemDiscountPercent > 100)
        {
            _itemDiscountMessage = "Desconto deve estar entre 0 e 100.";
            return;
        }
        if (_itemNewListPrice is < 0)
        {
            _itemDiscountMessage = "Preço inválido.";
            return;
        }

        _itemDiscountBusy = true;
        try
        {
            await OrderService.UpdateOrderProductDiscountAsync(
                OrderId,
                _discountItem.ProductId,
                _itemDiscountPercent,
                _itemNewListPrice);
            FecharModalDescontoItem();
            await CarregarDetalhesAsync();
        }
        catch (Exception ex)
        {
            _itemDiscountMessage = ex.Message;
        }
        finally
        {
            _itemDiscountBusy = false;
        }
    }

