            await OrderService.ReopenOrderAsync(OrderId);
            Navigation.NavigateTo($"/vendas/os/{OrderId}", forceLoad: true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task EfetuarVenda()
    {
        if (_header == null || !_showPerformSale) return;
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Deseja mesmo efetuar esta venda?");
