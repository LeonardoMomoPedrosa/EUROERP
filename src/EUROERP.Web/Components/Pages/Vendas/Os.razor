    private async Task AplicarCreditoDescontoAsync()
    {
        _extraMessage = null;
        var discount = _discount ?? 0;
        if (discount < 0 || discount > 100) { _extraMessage = "Desconto deve estar entre 0 e 100."; return; }
        _aplicando = true;
        try
        {
            await OrderService.UpdateOrderExtraTaxesAsync(OrderId, discount, _credit ?? 0, _otherExpenses ?? 0, _shipmentCost ?? 0, _chargeShipment);
            await OrderService.UpdateOrderCarKmAndProblemAsync(OrderId, _carKm, _carProblem);
            await CarregarDetalhesAsync();
            if (_header != null)
            {
                _credit = _header.Credit;
                _discount = _header.Discount;
                _otherExpenses = _header.OtherExpenses;
                _shipmentCost = _header.ShipmentCost;
                _chargeShipment = _header.ChargeShipment;
            }
        }
        catch (Exception ex)
        {
            _extraMessage = ex.Message;
        }
        finally
        {
            _aplicando = false;
        }
    }

    private async Task Continuar()
    {
        _extraMessage = null;
        var discount = _discount ?? 0;
        if (discount < 0 || discount > 100) { _extraMessage = "Desconto deve estar entre 0 e 100."; return; }
        _busy = true;
        try
        {
            await OrderService.UpdateOrderExtraTaxesAsync(OrderId, discount, _credit ?? 0, _otherExpenses ?? 0, _shipmentCost ?? 0, _chargeShipment);
            await OrderService.UpdateOrderCarKmAndProblemAsync(OrderId, _carKm, _carProblem);
            Navigation.NavigateTo($"/vendas/os/{OrderId}/pagamento", forceLoad: false);
        }
        catch (Exception ex)
        {
            _extraMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

