        <button type="button" class="btn btn-sm btn-warning" @onclick="ZerarCarrinho" disabled="@_busy">ZERAR</button>
        <button type="button" class="btn btn-sm btn-success" @onclick="Continuar" disabled="@_busy">Continuar</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="Sair">Sair</button>
