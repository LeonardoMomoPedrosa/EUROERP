@page "/vendas/nfe/nfes"
@using EUROERP.Application.Nfes
@rendermode InteractiveServer

<PageTitle>Enviar NFES</PageTitle>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="mb-0">NFe de Serviços (NFES)</h5>
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            Informe o número da OS fechada no Eurobus (status Fechado ou Enviado).
            @if (_preview?.Provider is not null)
            {
                <span>Provedor: <strong>@_preview.Provider</strong> (Santana de Parnaíba — Simpliss / layout nacional DPS).</span>
            }
            else
            {
                <span>Emissão via Simpliss (Santana de Parnaíba) — layout nacional DPS, certificado digital.</span>
            }
            A impressão da NFS-e consulta o webservice Simpliss (ou XML local), gera o DANFSe em PDF e abre para impressão.
        </p>
        <div class="row g-2 align-items-end mb-3">
            <div class="col-md-3">
                <label class="form-label">Número da OS</label>
                <input type="text" inputmode="numeric" class="form-control form-control-sm" @bind="_orderIdText" @bind:after="OnOrderIdChanged" placeholder="Ex: 24783" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Número RPS</label>
                <input type="text" class="form-control form-control-sm" @bind="_rpsNumber" readonly="@(!_isReprint)" />
            </div>
            <div class="col-auto">
                <label class="form-label d-block invisible" aria-hidden="true">&nbsp;</label>
                <button type="button" class="btn btn-primary btn-sm px-2" @onclick="CarregarPreview" disabled="@_loading">@(_loading ? "..." : "Carregar")</button>
            </div>
        </div>

        @if (_preview != null)
        {
            <div class="border rounded p-3 mb-3 small bg-light">
                <div><strong>Cliente:</strong> @_preview.ClientName <span class="text-muted">(#@_preview.ClientId)</span></div>
                <div><strong>Status:</strong> @_preview.Status</div>
                <div><strong>Total serviços:</strong> <span class="text-success fw-semibold">R$ @_preview.ServiceTotal.ToString("N2")</span></div>
                @if (!string.IsNullOrEmpty(_preview.NfesNo))
                {
                    <div class="text-danger mt-1"><strong>NFES já emitida:</strong> @_preview.NfesNo</div>
                    @if (!string.IsNullOrEmpty(_preview.PrintUrl))
                    {
                        <div class="mt-2">
                            @if (!string.IsNullOrEmpty(_preview.NfesChaveAcesso))
                            {
                                <div class="mb-1"><strong>Chave NFS-e:</strong> <span class="font-monospace user-select-all">@_preview.NfesChaveAcesso</span></div>
                            }
                            <a class="btn btn-outline-primary btn-sm" href="@_preview.PrintUrl" target="_blank" rel="noopener noreferrer">Imprimir NFS-e (PDF)</a>
                        </div>
                    }
                }
                @if (!string.IsNullOrEmpty(_preview.BlockReason) && !_preview.CanEmit)
                {
                    <div class="text-warning mt-1">@_preview.BlockReason</div>
                }
            </div>
        }

        <div class="d-flex gap-2">
            <button type="button" class="btn btn-success btn-sm" @onclick="Emitir" disabled="@(_emitting || _preview == null || (!_preview.CanEmit && !_isReprint))">
                @(_emitting ? "Enviando..." : "Enviar NFE de Serviços")
            </button>
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Limpar">Limpar</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_success ? "alert-success" : "alert-danger")">
        @_message
        @if (_success && !string.IsNullOrEmpty(_printUrl))
        {
            <div class="mt-2">
                @if (!string.IsNullOrEmpty(_nfesChaveAcesso))
                {
                    <div class="mb-1"><strong>Chave NFS-e:</strong> <span class="font-monospace user-select-all">@_nfesChaveAcesso</span></div>
                }
                <a class="btn btn-outline-primary btn-sm" href="@_printUrl" target="_blank" rel="noopener noreferrer">Imprimir NFS-e (PDF)</a>
            </div>
        }
    </div>
}

@code {
    private string _orderIdText = "";
    private string _rpsNumber = "";
    private NfesOrderPreviewDto? _preview;
    private bool _loading;
    private bool _emitting;
    private string? _message;
    private bool _success;
    private string? _printUrl;
    private string? _nfesChaveAcesso;
    private bool _isReprint => _rpsNumber.TrimStart().StartsWith("R", StringComparison.OrdinalIgnoreCase);

    [Inject] private INfesEmissionService NfesService { get; set; } = null!;

    protected override async Task OnInitializedAsync() => await RefreshRpsNumberAsync();

    private async Task RefreshRpsNumberAsync()
    {
        if (_isReprint)
            return;
        _rpsNumber = (await NfesService.GetNextRpsNumberAsync()).ToString();
    }

    private async Task OnOrderIdChanged()
    {
        if (!TryGetOrderId(out _))
        {
            _preview = null;
            return;
        }
        await CarregarPreview();
    }

    private bool TryGetOrderId(out int orderId)
    {
        orderId = 0;
        return int.TryParse(_orderIdText.Trim(), out orderId) && orderId > 0;
    }

    private async Task CarregarPreview()
    {
        if (!TryGetOrderId(out var orderId)) return;
        _loading = true;
        _message = null;
        try
        {
            _preview = await NfesService.GetOrderPreviewAsync(orderId);
            if (_preview == null)
            {
                _message = "OS não encontrada.";
                _success = false;
                return;
            }
            if (!_isReprint)
                await RefreshRpsNumberAsync();
            else if (string.IsNullOrWhiteSpace(_rpsNumber) && !string.IsNullOrWhiteSpace(_preview.RpsNo))
                _rpsNumber = "R" + _preview.RpsNo;
        }
        catch (Exception ex)
        {
            _message = ex.Message;
            _success = false;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Emitir()
    {
        if (!TryGetOrderId(out var orderId)) return;
        _emitting = true;
        _message = null;
        _printUrl = null;
        _nfesChaveAcesso = null;
        try
        {
            var result = await NfesService.EmitAsync(new EmitNfesRequest
            {
                OrderId = orderId,
                RpsNumber = _rpsNumber
            });
            _success = result.Success;
            _printUrl = result.PrintUrl;
            _nfesChaveAcesso = result.NfesChaveAcesso;
            _message = result.Success
                ? result.Message
                : result.Message;
            if (result.Success)
            {
                _preview = await NfesService.GetOrderPreviewAsync(orderId);
                await RefreshRpsNumberAsync();
            }
        }
        catch (Exception ex)
        {
            _success = false;
            _message = ex.Message;
        }
        finally
        {
            _emitting = false;
        }
    }

    private async Task Limpar()
    {
        _orderIdText = "";
        _preview = null;
        _message = null;
        _printUrl = null;
        _nfesChaveAcesso = null;
        await RefreshRpsNumberAsync();
    }
}
