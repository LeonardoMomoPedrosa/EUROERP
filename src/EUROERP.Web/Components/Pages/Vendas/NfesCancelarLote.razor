@page "/vendas/nfe/cancelar-lote"
@using EUROERP.Application.Nfes
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<PageTitle>Cancelar NFES</PageTitle>

<div class="d-flex flex-column gap-3">
    <div class="card">
        <div class="card-body py-3">
            <h6 class="card-title mb-1">Cancelar NFS-e de Serviços</h6>
            <p class="text-muted small mb-3">
                Santana de Parnaíba — cancelamento via Simpliss (evento nacional e101101). Informe o número da NFS-e,
                a data do cancelamento e o motivo (mínimo 15 caracteres).
            </p>
            <div class="row align-items-end g-3">
                <div class="col-auto">
                    <label class="form-label small text-muted mb-0" for="cancelDateNfes">Data</label>
                    <input id="cancelDateNfes" type="date" class="form-control form-control-sm" @bind="_cancelDate" style="width: 11rem;" />
                </div>
                <div class="col-auto">
                    <label class="form-label small text-muted mb-0">Número NF Serviço</label>
                    <input type="text" inputmode="numeric" class="form-control form-control-sm text-end" @bind="_nfesNoText" placeholder="Nº" style="width: 7rem;" />
                </div>
                <div class="col-auto">
                    <label class="form-label small text-muted mb-0">Cód. motivo</label>
                    <select class="form-select form-select-sm" @bind="_motivoCode" style="width: 14rem;">
                        <option value="1">1 — Erro na emissão</option>
                        <option value="2">2 — Serviço não prestado</option>
                        <option value="9">9 — Outros</option>
                    </select>
                </div>
                <div class="col">
                    <label class="form-label small text-muted mb-0">Motivo (mín. 15 caracteres)</label>
                    <textarea class="form-control form-control-sm" @bind="_memo" rows="1" maxlength="200" placeholder="Justificativa do cancelamento" style="min-width: 16rem;"></textarea>
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-danger btn-sm" @onclick="OnCancelar" disabled="@_submitting">
                        @(_submitting ? "Aguarde..." : "Cancelar NFES")
                    </button>
                </div>
            </div>
            @if (_result != null)
            {
                <div class="mt-3 pt-3 border-top small @(_result.Success ? "text-success" : "text-danger")">
                    @_result.Message
                    @if (_result.Success && _result.OrderId is int orderId)
                    {
                        <span class="d-block mt-1 text-muted">Pedido (OS) #@orderId</span>
                    }
                </div>
            }
        </div>
    </div>

    <div class="card grid-card">
        <div class="card-header py-2">
            <h6 class="mb-0">Cancelamentos de hoje</h6>
        </div>
        @if (_listLoading)
        {
            <div class="card-body py-4 text-center text-muted">
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                Carregando...
            </div>
        }
        else if (_todayCanceled.Count == 0)
        {
            <div class="card-body py-4">
                <p class="text-muted mb-0 small">Nenhum cancelamento registrado hoje.</p>
            </div>
        }
        else
        {
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 7rem;">Data</th>
                                <th style="width: 6rem;">Nota #</th>
                                <th>Motivo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _todayCanceled)
                            {
                                <tr>
                                    <td class="text-nowrap">@item.CancelDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.ReceiptNo</td>
                                    <td title="@item.Memo">@item.Memo</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private DateTime _cancelDate = DateTime.Today;
    private string _nfesNoText = "";
    private string _memo = "";
    private string _motivoCode = "9";
    private bool _submitting;
    private CancelNfesResult? _result;
    private IReadOnlyList<NfesCanceledReceiptDto> _todayCanceled = Array.Empty<NfesCanceledReceiptDto>();
    private bool _listLoading = true;
    private string? _userId;

    [Inject] private INfesCancellationService CancellationService { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = state.User.Identity?.Name ?? "SYS";
        await LoadTodayCanceledAsync();
    }

    private async Task LoadTodayCanceledAsync()
    {
        _listLoading = true;
        try
        {
            _todayCanceled = await CancellationService.GetTodayCanceledAsync();
        }
        finally
        {
            _listLoading = false;
        }
    }

    private async Task OnCancelar()
    {
        _result = null;

        if (!int.TryParse(_nfesNoText.Trim(), out var nfesNo) || nfesNo < 1)
        {
            _result = new CancelNfesResult { Success = false, Message = "Informe o número da NFS-e de serviços." };
            return;
        }

        var memo = _memo?.Trim() ?? "";
        if (memo.Length < 15)
        {
            _result = new CancelNfesResult { Success = false, Message = "O motivo deve ter no mínimo 15 caracteres." };
            return;
        }

        _submitting = true;
        try
        {
            _result = await CancellationService.CancelAsync(new CancelNfesRequest
            {
                CancelDate = _cancelDate.Date,
                NfesNo = nfesNo,
                Memo = memo,
                MotivoCode = _motivoCode,
                UserId = _userId ?? "SYS",
                ApplicationId = "EUROERP"
            });

            if (_result.Success)
            {
                await LoadTodayCanceledAsync();
                _nfesNoText = "";
                _memo = "";
                _motivoCode = "9";
                _cancelDate = DateTime.Today;
            }
        }
        finally
        {
            _submitting = false;
        }
    }
}
